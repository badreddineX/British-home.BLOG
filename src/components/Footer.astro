---
import CookieConsent from './CookieConsent.astro';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-cols">

      <!-- Brand -->
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <svg width="34" height="34" viewBox="0 0 36 36" fill="none">
            <circle cx="18" cy="18" r="17" stroke="#B89A6A" stroke-width="1.2"/>
            <path d="M7 21 L18 10 L29 21" stroke="#B89A6A" stroke-width="1.2" fill="none"/>
            <rect x="12" y="21" width="5" height="6" stroke="#B89A6A" stroke-width="1" fill="none"/>
            <rect x="19" y="21" width="5" height="6" stroke="#B89A6A" stroke-width="1" fill="none"/>
            <path d="M5 26 Q18 19 31 26" stroke="#B89A6A" stroke-width="1" fill="none"/>
          </svg>
          <span class="footer-logo-text">
            <span class="footer-logo-name">British Home Interior</span>
            <span class="footer-logo-tag">Styling &amp; Room Makeovers</span>
          </span>
        </a>
        <p class="footer-brand-desc">Cosy styling, room makeovers, and interior ideas for UK homes, flats, and Victorian terraces — in British English, in pounds.</p>
      </div>

      <!-- Nav -->
      <nav class="footer-nav" aria-label="Footer navigation">
        <a href="/" class="footer-nav-link">Home</a>
        <a href="/about/" class="footer-nav-link">About Me</a>
        <a href="/blog/" class="footer-nav-link">All Articles</a>
        <a href="/blog/?category=living-room" class="footer-nav-link">Living Room</a>
        <a href="/blog/?category=bedroom" class="footer-nav-link">Bedroom</a>
        <a href="/blog/?category=kitchen" class="footer-nav-link">Kitchen</a>
        <a href="/blog/?category=room-makeovers" class="footer-nav-link">Room Makeovers</a>
        <a href="/privacy-policy/" class="footer-nav-link footer-nav-link--policy">Privacy Policy</a>
      </nav>

      <!-- Newsletter -->
      <div class="footer-newsletter">
        <p class="footer-newsletter-heading">Get the latest styling tips and cosy home inspiration straight to your inbox!</p>
        <form class="footer-form" id="footer-newsletter-form" novalidate>
          <label for="footer-email" class="footer-form-label">Email *</label>
          <input id="footer-email" type="email" placeholder="Your email address" class="footer-input" required />
          <div class="footer-checkbox-row">
            <input type="checkbox" id="footer-consent" required />
            <label for="footer-consent">Yes, subscribe me to your newsletter</label>
          </div>
          <button type="submit" class="footer-submit">Subscribe</button>
        </form>
        <p class="footer-newsletter-thanks" id="footer-newsletter-thanks" hidden>
          Thanks for subscribing! 🏡 You'll hear from us soon.
        </p>
      </div>

    </div>

    <!-- Social row -->
    <div class="footer-social-row">
      <a href="https://facebook.com" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="footer-social-btn footer-social-fb">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
      </a>
      <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="footer-social-btn footer-social-ig">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
      </a>
      <a href="https://youtube.com" target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="footer-social-btn footer-social-yt">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.965C5.12 20 12 20 12 20s6.88 0 8.59-.455a2.78 2.78 0 0 0 1.95-1.965A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58zM9.75 15.02V8.98L15.5 12l-5.75 3.02z"/></svg>
      </a>
    </div>

    <div class="footer-bottom">
      <p>&copy; {year} by British Home Interior. All rights reserved.</p>
      <p><a href="/privacy-policy/" class="footer-policy-link">Privacy Policy</a></p>
    </div>
  </div>
</footer>

<CookieConsent />

<style>
  .site-footer { background: var(--color-dark); color: rgba(255,255,255,0.6); }

  .footer-inner { max-width: 1200px; margin-inline: auto; padding-inline: 2rem; }

  .footer-cols {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    padding-block: 4rem 3rem;
  }

  @media (min-width: 768px) {
    .footer-cols { grid-template-columns: 1.4fr 0.8fr 1.4fr; }
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
    margin-bottom: 1rem;
  }

  .footer-logo-text { display: flex; flex-direction: column; }

  .footer-logo-name {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 700;
    color: #fff;
    line-height: 1.1;
  }

  .footer-logo-tag { font-size: 0.6rem; color: rgba(255,255,255,0.4); font-style: italic; letter-spacing: 0.04em; }

  .footer-brand-desc { font-size: 0.82rem; line-height: 1.65; color: rgba(255,255,255,0.4); margin: 0; max-width: 260px; }

  .footer-nav { display: flex; flex-direction: column; gap: 0.65rem; }

  .footer-nav-link { font-size: 0.875rem; color: rgba(255,255,255,0.55); text-decoration: none; transition: color 200ms; }
  .footer-nav-link:hover { color: rgba(255,255,255,0.9); text-decoration: none; }
  .footer-nav-link--policy { margin-top: 0.5rem; padding-top: 0.75rem; border-top: 1px solid rgba(255,255,255,0.1); font-size: 0.78rem; color: rgba(255,255,255,0.38); }
  .footer-nav-link--policy:hover { color: rgba(255,255,255,0.75); }

  .footer-newsletter-heading { font-family: var(--font-display); font-size: 1rem; font-weight: 700; color: #fff; line-height: 1.35; margin: 0 0 1.25rem; }

  .footer-form { display: flex; flex-direction: column; gap: 0.75rem; }

  .footer-form-label { font-size: 0.78rem; color: rgba(255,255,255,0.5); }

  .footer-input {
    width: 100%;
    border: 1px solid rgba(255,255,255,0.2);
    background: rgba(255,255,255,0.05);
    padding: 0.65rem 0.85rem;
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: rgba(255,255,255,0.85);
    outline: none;
    box-sizing: border-box;
  }
  .footer-input::placeholder { color: rgba(255,255,255,0.3); }
  .footer-input:focus { border-color: var(--color-gold); }

  .footer-checkbox-row { display: flex; align-items: flex-start; gap: 0.5rem; font-size: 0.78rem; color: rgba(255,255,255,0.5); }
  .footer-checkbox-row input { margin-top: 2px; flex-shrink: 0; accent-color: var(--color-gold); }

  .footer-submit {
    align-self: flex-start;
    background: var(--color-gold);
    color: #fff;
    border: none;
    padding: 0.65rem 1.5rem;
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 700;
    cursor: pointer;
    transition: background 200ms;
  }
  .footer-submit:hover { background: #9a7f52; }

  .footer-social-row {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    padding-block: 1.5rem;
    border-top: 1px solid rgba(255,255,255,0.08);
  }

  .footer-social-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.15);
    color: rgba(255,255,255,0.6);
    text-decoration: none;
    transition: background-color 200ms, color 200ms, border-color 200ms;
  }
  .footer-social-btn:hover { text-decoration: none; color: #fff; border-color: transparent; }
  .footer-social-fb:hover  { background: #1877F2; }
  .footer-social-ig:hover  { background: #E1306C; }
  .footer-social-pin:hover { background: #E60023; }
  .footer-social-yt:hover  { background: #FF0000; }

  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.08);
    padding-block: 1.25rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    justify-content: center;
    text-align: center;
  }

  .footer-bottom p { font-size: 0.72rem; color: rgba(255,255,255,0.22); margin: 0; width: 100%; }

  .footer-policy-link { color: rgba(255,255,255,0.35); text-decoration: underline; text-underline-offset: 2px; }
  .footer-policy-link:hover { color: rgba(255,255,255,0.7); text-decoration: underline; }

  .footer-newsletter-thanks {
    font-size: 0.85rem;
    color: var(--color-gold);
    margin: 0.75rem 0 0;
    line-height: 1.5;
  }
</style>

<script>
  const form   = document.getElementById('footer-newsletter-form') as HTMLFormElement | null;
  const thanks = document.getElementById('footer-newsletter-thanks') as HTMLElement | null;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const email   = (form.querySelector('#footer-email') as HTMLInputElement).value.trim();
    const consent = (form.querySelector('#footer-consent') as HTMLInputElement).checked;
    if (!email || !consent) return;
    form.hidden  = true;
    if (thanks) thanks.hidden = false;
  });
</script>
