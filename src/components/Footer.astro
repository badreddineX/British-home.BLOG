---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-cols">

      <div class="footer-col footer-brand-col">
        <a href="/" class="footer-logo">British Home Interior<span class="footer-logo-dot">.</span></a>
        <p>Cosy styling, room makeovers, and interior ideas for UK homes, flats, and Victorian terraces — in British English, in pounds.</p>
        <div class="footer-social">
          <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="footer-social-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
          </a>
          <a href="https://pinterest.co.uk" target="_blank" rel="noopener noreferrer" aria-label="Pinterest" class="footer-social-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
          </a>
          <a href="https://facebook.com" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="footer-social-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
        </div>
      </div>

      <div class="footer-col">
        <span class="footer-col-title">Quick Links</span>
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/blog/">All Articles</a></li>
          <li><a href="/blog/?category=room-makeovers">Room Makeovers</a></li>
          <li><a href="/about/">About</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <span class="footer-col-title">Categories</span>
        <ul>
          <li><a href="/blog/?category=living-room">Living Room</a></li>
          <li><a href="/blog/?category=bedroom">Bedroom</a></li>
          <li><a href="/blog/?category=kitchen">Kitchen</a></li>
          <li><a href="/blog/?category=room-makeovers">Room Makeovers</a></li>
        </ul>
      </div>

    </div>

    <div class="footer-bottom">
      <p>&copy; {year} British Home Interior. All rights reserved.</p>
      <p>Affiliate disclosure: some links earn a small commission at no extra cost to you.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-dark, #1A1212);
    color: rgba(255,255,255,0.6);
    margin-top: 0;
  }

  .footer-inner {
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: 2rem;
  }

  .footer-cols {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    padding-block: 3.5rem 2.5rem;
  }

  @media (min-width: 640px) {
    .footer-cols { grid-template-columns: 2fr 1fr 1fr; gap: 2rem; }
  }

  .footer-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-col a {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.55);
    text-decoration: none;
    transition: color var(--transition-base);
  }
  .footer-col a:hover { color: rgba(255,255,255,0.9); text-decoration: none; }

  .footer-logo {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 700;
    color: rgba(255,255,255,0.9) !important;
    display: block;
    margin-bottom: 0.75rem;
  }
  .footer-logo-dot { color: var(--color-gold); }

  .footer-brand-col p {
    font-size: 0.82rem;
    line-height: 1.6;
    color: rgba(255,255,255,0.4);
    margin: 0 0 1.25rem;
    max-width: 260px;
  }

  .footer-col-title {
    display: block;
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
    margin-bottom: 1rem;
  }

  /* Social icons */
  .footer-social {
    display: flex;
    gap: 0.6rem;
  }

  .footer-social-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border: 1px solid rgba(255,255,255,0.15);
    color: rgba(255,255,255,0.5);
    text-decoration: none;
    transition: border-color var(--transition-base), color var(--transition-base);
  }
  .footer-social-btn:hover { border-color: var(--color-white); color: var(--color-white); text-decoration: none; }

  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.08);
    padding-block: 1.25rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: space-between;
  }

  .footer-bottom p {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.25);
    margin: 0;
  }
</style>
