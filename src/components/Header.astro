---
const categories = [
  { label: 'Living Room',    href: '/blog/?category=living-room' },
  { label: 'Bedroom',        href: '/blog/?category=bedroom' },
  { label: 'Kitchen',        href: '/blog/?category=kitchen' },
  { label: 'Room Makeovers', href: '/blog/?category=room-makeovers' },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <nav class="header-nav" aria-label="Main navigation">

    <!-- Logo -->
    <a href="/" class="header-logo" aria-label="British Home Interior">
      <span class="logo-icon" aria-hidden="true">
        <svg width="36" height="36" viewBox="0 0 36 36" fill="none">
          <circle cx="18" cy="18" r="17" stroke="#B89A6A" stroke-width="1.2"/>
          <path d="M7 21 L18 10 L29 21" stroke="#B89A6A" stroke-width="1.2" fill="none"/>
          <rect x="12" y="21" width="5" height="6" stroke="#B89A6A" stroke-width="1" fill="none"/>
          <rect x="19" y="21" width="5" height="6" stroke="#B89A6A" stroke-width="1" fill="none"/>
          <path d="M5 26 Q18 19 31 26" stroke="#B89A6A" stroke-width="1" fill="none"/>
        </svg>
      </span>
      <span class="logo-text">
        <span class="logo-name">British Home Interior</span>
        <span class="logo-tag">Styling &amp; Room Makeovers</span>
      </span>
    </a>

    <!-- Nav links + CTA -->
    <div class="nav-inner" id="nav-menu">
      <a href="/" class={`nav-link ${currentPath === '/' ? 'active' : ''}`}>Home</a>

      <div class="nav-dropdown-wrap">
        <a href="/blog/" class={`nav-link ${currentPath.startsWith('/blog') ? 'active' : ''}`} aria-haspopup="true">
          Read
          <svg class="dropdown-chevron" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
        </a>
        <div class="nav-dropdown" role="menu">
          {categories.map(cat => (
            <a href={cat.href} class="nav-dropdown-item" role="menuitem">{cat.label}</a>
          ))}
        </div>
      </div>

      <a href="/about/" class={`nav-link ${currentPath === '/about/' ? 'active' : ''}`}>About</a>

      <!-- Divider -->
      <span class="nav-rule" aria-hidden="true"></span>

      <!-- CTA -->
      <a href="/blog/" class="nav-cta" aria-label="Browse all ideas">
        <span class="nav-cta-main">Browse Ideas</span>
        <span class="nav-cta-sub">Start Here</span>
      </a>
    </div>

    <!-- Mobile toggle -->
    <button class="mobile-toggle" aria-expanded="false" aria-controls="mobile-nav" aria-label="Open menu">
      <span></span><span></span><span></span>
    </button>

  </nav>

  <!-- Mobile nav -->
  <div id="mobile-nav" class="mobile-nav">
    <a href="/" class="mobile-link">Home</a>
    <span class="mobile-cat-label">Read</span>
    {categories.map(cat => (
      <a href={cat.href} class="mobile-link mobile-link-sub">{cat.label}</a>
    ))}
    <a href="/about/" class="mobile-link">About</a>
    <a href="/blog/" class="mobile-link mobile-link-cta">Browse Ideas →</a>
  </div>
</header>

<!-- Fixed right social sidebar (hidden on blog pages) -->
<aside class={`social-sidebar${currentPath.startsWith('/blog') ? ' social-sidebar--hidden' : ''}`} aria-label="Follow us">
  <a href="https://instagram.com/britishhomeinterior" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="social-sidebar-btn">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
  </a>
  <a href="https://pinterest.co.uk/britishhomeinterior" target="_blank" rel="noopener noreferrer" aria-label="Pinterest" class="social-sidebar-btn">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
  </a>
  <a href="https://reddit.com/r/BritishHomeInterior" target="_blank" rel="noopener noreferrer" aria-label="Reddit" class="social-sidebar-btn">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 0 1 .042.52c0 2.694-3.13 4.87-7.004 4.87-3.874 0-7.004-2.176-7.004-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 0 1 4.028 12c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 0 1 .14-.197.35.35 0 0 1 .238-.042l2.906.617a1.214 1.214 0 0 1 1.108-.701zM9.25 12C8.561 12 8 12.562 8 13.25c0 .687.561 1.248 1.25 1.248.687 0 1.248-.561 1.248-1.249 0-.688-.561-1.249-1.249-1.249zm5.5 0c-.687 0-1.248.561-1.248 1.25 0 .687.561 1.248 1.249 1.248.688 0 1.249-.561 1.249-1.249 0-.687-.562-1.249-1.25-1.249zm-5.466 3.99a.327.327 0 0 0-.231.094.33.33 0 0 0 0 .463c.842.842 2.484.913 2.961.913.477 0 2.105-.056 2.961-.913a.361.361 0 0 0 .029-.463.33.33 0 0 0-.464 0c-.547.533-1.684.73-2.512.73-.828 0-1.979-.196-2.512-.73a.326.326 0 0 0-.232-.095z"/></svg>
  </a>
</aside>

<script>
  const mobileToggle = document.querySelector('.mobile-toggle') as HTMLButtonElement;
  const mobileNav = document.getElementById('mobile-nav') as HTMLElement;
  mobileToggle?.addEventListener('click', () => {
    const open = mobileToggle.getAttribute('aria-expanded') === 'true';
    mobileToggle.setAttribute('aria-expanded', String(!open));
    mobileNav?.classList.toggle('is-open', !open);
  });
</script>

<style>
  .site-header {
    background: var(--color-dark);
    position: sticky;
    top: 0;
    z-index: 200;
  }

  .header-nav {
    max-width: 1300px;
    margin-inline: auto;
    padding-inline: 2rem;
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .header-logo {
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.65rem;
    flex-shrink: 0;
  }

  .logo-text { display: flex; flex-direction: column; }

  .logo-name {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 700;
    color: #fff;
    line-height: 1.1;
    white-space: nowrap;
  }

  .logo-tag {
    font-family: var(--font-body);
    font-size: 0.62rem;
    color: rgba(255,255,255,0.45);
    letter-spacing: 0.05em;
    font-style: italic;
    white-space: nowrap;
  }

  /* Nav row */
  .nav-inner {
    display: flex;
    align-items: center;
    gap: 0;
  }

  .nav-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: rgba(255,255,255,0.6);
    text-decoration: none;
    padding: 0 1rem;
    height: 72px;
    transition: color 200ms ease;
    white-space: nowrap;
  }
  .nav-link:hover { color: rgba(255,255,255,0.95); text-decoration: none; }

  /* Active underline */
  .nav-link.active {
    color: rgba(255,255,255,0.95);
  }
  .nav-link.active::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 1rem;
    right: 1rem;
    height: 2px;
    background: rgba(255,255,255,0.65);
  }

  /* Dropdown */
  .nav-dropdown-wrap { position: relative; display: flex; align-items: center; }

  .nav-dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 190px;
    background: var(--color-dark);
    border-top: 2px solid var(--color-gold);
    padding: 0.5rem 0;
    opacity: 0;
    visibility: hidden;
    transform: translateY(6px);
    transition: opacity 200ms ease, transform 200ms ease, visibility 200ms ease;
    z-index: 300;
    box-shadow: 0 8px 24px rgba(0,0,0,0.35);
  }

  .nav-dropdown-wrap:hover .nav-dropdown,
  .nav-dropdown-wrap:focus-within .nav-dropdown {
    opacity: 1; visibility: visible; transform: translateY(0);
  }

  .nav-dropdown-wrap:hover .dropdown-chevron,
  .nav-dropdown-wrap:focus-within .dropdown-chevron { transform: rotate(180deg); }

  .dropdown-chevron { transition: transform 200ms ease; }

  .nav-dropdown-item {
    display: block;
    padding: 0.6rem 1.25rem;
    font-size: 0.85rem;
    color: rgba(255,255,255,0.7);
    text-decoration: none;
    transition: background-color 150ms, color 150ms;
  }
  .nav-dropdown-item:hover { background: rgba(255,255,255,0.06); color: var(--color-gold); text-decoration: none; }

  /* Vertical rule divider */
  .nav-rule {
    display: block;
    width: 1px;
    height: 28px;
    background: rgba(255,255,255,0.18);
    margin-inline: 1rem;
    flex-shrink: 0;
  }

  /* CTA — BROWSE IDEAS / START HERE */
  .nav-cta {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-decoration: none;
    padding: 0 0.5rem;
    gap: 0.1rem;
    transition: opacity 200ms;
  }
  .nav-cta:hover { opacity: 0.8; text-decoration: none; }

  .nav-cta-main {
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #fff;
    line-height: 1;
  }

  .nav-cta-sub {
    font-family: var(--font-body);
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.38);
    line-height: 1;
  }

  /* Mobile toggle */
  .mobile-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.4rem;
    flex-shrink: 0;
  }
  .mobile-toggle span { display: block; width: 22px; height: 1.5px; background: rgba(255,255,255,0.85); }

  .mobile-nav {
    display: none;
    flex-direction: column;
    background: var(--color-dark);
    border-top: 1px solid rgba(255,255,255,0.08);
    padding-block: 0.5rem;
  }
  .mobile-nav.is-open { display: flex; }

  .mobile-link {
    font-size: 0.95rem;
    color: rgba(255,255,255,0.8);
    text-decoration: none;
    padding: 0.65rem 2rem;
    transition: color 200ms;
  }
  .mobile-link:hover { color: #fff; text-decoration: none; }
  .mobile-link-sub { font-size: 0.85rem; color: rgba(255,255,255,0.5); padding-left: 2.75rem; padding-block: 0.45rem; }

  .mobile-link-cta {
    margin-top: 0.25rem;
    border-top: 1px solid rgba(255,255,255,0.08);
    padding-top: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--color-gold);
  }
  .mobile-link-cta:hover { color: #fff; }

  .mobile-cat-label {
    display: block;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
    padding: 0.65rem 2rem 0.2rem;
  }

  @media (max-width: 700px) {
    .nav-inner { display: none; }
    .mobile-toggle { display: flex; }
  }

  /* ===== FIXED SOCIAL SIDEBAR ===== */
  .social-sidebar {
    position: fixed;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    z-index: 150;
    display: flex;
    flex-direction: column;
    background: var(--color-gold);
    box-shadow: -2px 0 12px rgba(0,0,0,0.12);
  }

  .social-sidebar-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    color: #fff;
    text-decoration: none;
    transition: background-color 200ms;
  }
  .social-sidebar-btn { transition: background-color 200ms, color 200ms; }
  .social-sidebar-btn:nth-child(1):hover { background: #1877F2; color: #fff; text-decoration: none; }
  .social-sidebar-btn:nth-child(2):hover { background: #E1306C; color: #fff; text-decoration: none; }
  .social-sidebar-btn:nth-child(3):hover { background: #E60023; color: #fff; text-decoration: none; }
  .social-sidebar-btn:nth-child(4):hover { background: #FF0000; color: #fff; text-decoration: none; }

  @media (max-width: 900px) { .social-sidebar { display: none; } }
  .social-sidebar--hidden { display: none !important; }
</style>
