---
interface Props {
  points: string[];
  title?: string;
}

const { points, title = 'At a Glance' } = Astro.props;
---

<aside class="tldr-box" aria-label="Summary">
  <p class="tldr-title">{title}</p>
  <ul>
    {points.map(point => <li>{point}</li>)}
  </ul>
</aside>

<style>
  .tldr-box {
    background: var(--color-surface);
    border-left: 4px solid var(--color-primary);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    padding: 1.25rem 1.5rem;
    margin: 2rem 0;
  }

  .tldr-title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-heading);
    margin-bottom: 0.75rem;
  }

  .tldr-box ul {
    margin-bottom: 0;
    padding-left: 1.25rem;
  }

  .tldr-box li {
    font-size: 0.95rem;
    color: var(--color-text);
    margin-bottom: 0.4rem;
    line-height: 1.6;
  }

  .tldr-box li:last-child {
    margin-bottom: 0;
  }
</style>
