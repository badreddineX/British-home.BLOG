---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';
import TLDRBox from '../components/TLDRBox.astro';
import FAQ from '../components/FAQ.astro';
import '../styles/global.css';
import { getCollection } from 'astro:content';

interface FAQItem { q: string; a: string; }

interface Props {
  title: string;
  description: string;
  slug: string;
  image: string;
  datePublished: string;
  dateModified: string;
  author?: string;
  category?: string;
  readTime?: string;
  tldr?: string[];
  faqs?: FAQItem[];
  headings?: { depth: number; slug: string; text: string }[];
}

const {
  title,
  description,
  slug,
  image,
  datePublished,
  dateModified,
  author = 'British Home Interior',
  category = 'Interiors',
  readTime = '5 min read',
  tldr = [],
  faqs = [],
  headings = [],
} = Astro.props;

const siteUrl = 'https://britishhomeinterior.co.uk';
const postUrl = `${siteUrl}/blog/${slug}/`;

const fmtDate = (d: string) =>
  new Date(d).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });

const h2s = headings.filter(h => h.depth === 2);

// Related posts: same category, excluding current
const allPosts = await getCollection('blog');
const related = allPosts
  .filter(p => p.slug !== slug && p.data.category?.toLowerCase() === category.toLowerCase())
  .sort((a, b) => new Date(b.data.datePublished).getTime() - new Date(a.data.datePublished).getTime())
  .slice(0, 3);
---

<html lang="en-GB">
  <head>
    <SEO
      title={title}
      description={description}
      slug={slug}
      image={image}
      datePublished={datePublished}
      dateModified={dateModified}
      authorName={author}
      type="article"
    />
  </head>
  <body>
    <Header />

    <main>

      <!-- ====== POST HERO ====== -->
      <div class="post-hero">
        <div class="img-wrap post-hero-img-wrap">
          <img
            src={image}
            alt={title}
            width="1400"
            height="560"
            loading="eager"
            decoding="async"
            class="post-hero-img"
          />
        </div>

        <!-- White title card floating over image -->
        <div class="post-hero-card">
          <div class="post-hero-social">
            <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(postUrl)}`} target="_blank" rel="noopener noreferrer" aria-label="Share on Facebook" class="post-hero-social-btn">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </a>
            <a href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(postUrl)}&text=${encodeURIComponent(title)}`} target="_blank" rel="noopener noreferrer" aria-label="Share on X / Twitter" class="post-hero-social-btn">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.74l7.73-8.835L1.254 2.25H8.08l4.259 5.631 5.905-5.631Zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
          </div>
          <span class="post-hero-cat">{category}</span>
          <h1 class="post-hero-title">{title}</h1>
          <p class="post-hero-desc">{description}</p>
          <p class="post-hero-meta">
            <time datetime={datePublished}>{fmtDate(datePublished)}</time>
            &nbsp;·&nbsp;{readTime}
          </p>
        </div>
      </div>

      <!-- ====== POST BODY: share | content | sidebar ====== -->
      <div class="post-body-wrap">

        <!-- Left sticky share panel (desktop only) -->
        <aside class="post-share-col" aria-label="Share this post">
          <div class="post-share-sticky">
            <span class="post-share-label">Share</span>
            <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(postUrl)}`} target="_blank" rel="noopener noreferrer" aria-label="Share on Facebook" class="post-share-btn">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </a>
            <a href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(postUrl)}&text=${encodeURIComponent(title)}`} target="_blank" rel="noopener noreferrer" aria-label="Share on X" class="post-share-btn">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.74l7.73-8.835L1.254 2.25H8.08l4.259 5.631 5.905-5.631Zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
          </div>
        </aside>

        <!-- Main content -->
        <article class="post-content-area">

          <!-- TL;DR -->
          {tldr.length > 0 && <TLDRBox points={tldr} />}

          <!-- Post body — drop cap on first paragraph -->
          <div class="post-content drop-cap">
            <slot />
          </div>

          <!-- FAQ -->
          {faqs.length > 0 && <FAQ questions={faqs} />}

          <!-- Author bio -->
          <div class="author-bio">
            <img src="https://images.pexels.com/photos/3771839/pexels-photo-3771839.jpeg?auto=compress&cs=tinysrgb&w=120&h=120&fit=crop" alt={author} width="56" height="56" loading="lazy" />
            <div>
              <span class="author-bio-name">{author}</span>
              <p class="author-bio-text">
                UK home enthusiast sharing cosy styling ideas, honest room makeovers, and budget interior inspiration for real British homes.
              </p>
            </div>
          </div>

        </article>

        <!-- Right sidebar — sticky TOC -->
        <aside class="post-sidebar" aria-label="Table of contents">
          {h2s.length > 0 && (
            <div class="toc-sidebar" id="toc-sidebar">
              <div class="toc-sidebar-header">
                <span>Table of Contents</span>
                <button class="toc-sidebar-toggle" id="toc-toggle" aria-label="Collapse table of contents">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m18 15-6-6-6 6"/></svg>
                </button>
              </div>
              <ol class="toc-sidebar-list" id="toc-sidebar-list">
                {h2s.map(h => (
                  <li>
                    <a href={`#${h.slug}`} class="toc-sidebar-link" data-slug={h.slug}>{h.text}</a>
                  </li>
                ))}
              </ol>
              <div class="toc-sidebar-footer">
                <span class="toc-sidebar-footer-label">More Ideas</span>
                <ul class="toc-sidebar-cats">
                  <li><a href="/blog/?category=living-room">Living Room</a></li>
                  <li><a href="/blog/?category=bedroom">Bedroom</a></li>
                  <li><a href="/blog/?category=kitchen">Kitchen</a></li>
                  <li><a href="/blog/?category=room-makeovers">Room Makeovers</a></li>
                </ul>
              </div>
            </div>
          )}
        </aside>
      </div>

      <!-- ====== RELATED ARTICLES ====== -->
      {related.length > 0 && (
        <section class="related-section" aria-label="Related articles">
          <div class="related-inner">
            <h2 class="related-title">Related Articles</h2>
            <div class="related-grid">
              {related.map(post => (
                <a href={`/blog/${post.slug}/`} class="related-card">
                  <div class="related-card-img img-wrap">
                    <img
                      src={post.data.image}
                      alt={post.data.title}
                      width="320"
                      height="220"
                      loading="lazy"
                      decoding="async"
                    />
                  </div>
                  <div class="related-card-body">
                    <span class="related-card-cat">{post.data.category ?? 'Interiors'}</span>
                    <span class="related-card-title">{post.data.title}</span>
                    <span class="related-card-meta">
                      <time datetime={post.data.datePublished}>{fmtDate(post.data.datePublished)}</time>
                      &nbsp;·&nbsp;{post.data.readTime ?? '5 mins read'}
                    </span>
                  </div>
                </a>
              ))}
            </div>
            <div class="related-back">
              <a href="/blog/" class="related-back-btn">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m15 18-6-6 6-6"/></svg>
                Back to All Articles
              </a>
            </div>
          </div>
        </section>
      )}

    </main>

    <Footer />
  </body>
</html>

<script>
  /* ---- TOC collapse toggle ---- */
  const tocToggle = document.getElementById('toc-toggle') as HTMLButtonElement | null;
  const tocList   = document.getElementById('toc-sidebar-list') as HTMLElement | null;

  tocToggle?.addEventListener('click', () => {
    const isCollapsed = tocList?.classList.contains('toc-collapsed');
    tocList?.classList.toggle('toc-collapsed', !isCollapsed);
    tocToggle.style.transform = isCollapsed ? 'rotate(0deg)' : 'rotate(180deg)';
  });

  /* ---- Active section highlighting via IntersectionObserver ---- */
  const tocLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('.toc-sidebar-link'));

  if (tocLinks.length) {
    const headingEls = tocLinks
      .map(a => document.getElementById(a.dataset.slug ?? ''))
      .filter(Boolean) as HTMLElement[];

    let activeLink: HTMLAnchorElement | null = null;
    let activeHeading: HTMLElement | null = null;

    const observer = new IntersectionObserver(
      entries => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const id = entry.target.id;

            // Update TOC active link
            activeLink?.classList.remove('active');
            activeLink = tocLinks.find(a => a.dataset.slug === id) ?? null;
            activeLink?.classList.add('active');

            // Update active H2 in article
            activeHeading?.classList.remove('active');
            activeHeading = document.getElementById(id);
            activeHeading?.classList.add('active');
          }
        });
      },
      { rootMargin: '-5% 0px -75% 0px', threshold: 0 }
    );

    headingEls.forEach(el => observer.observe(el));
  }
</script>

<style>
  /* ====== POST HERO ====== */
  .post-hero { width: 100%; background: var(--color-surface); }

  .post-hero-img-wrap {
    width: 100%;
    aspect-ratio: 21/8;
    overflow: hidden;
  }

  @media (max-width: 640px) {
    .post-hero-img-wrap { aspect-ratio: 4/3; }
  }

  .post-hero-img { width: 100%; height: 100%; object-fit: cover; }

  /* White card centred over image */
  .post-hero-card {
    background: #fff;
    max-width: 600px;
    margin-inline: auto;
    padding: 1.5rem 1.5rem 1.25rem;
    text-align: center;
    margin-top: -2rem;
    position: relative;
    z-index: 2;
    box-shadow: 0 4px 24px rgba(0,0,0,0.07);
  }

  @media (min-width: 768px) {
    .post-hero-card {
      margin-top: -4.5rem;
      padding: 2rem 3.5rem 1.75rem;
    }
  }

  .post-hero-social {
    display: flex;
    justify-content: center;
    gap: 1.25rem;
    margin-bottom: 0.8rem;
  }

  .post-hero-social-btn {
    color: var(--color-heading);
    text-decoration: none;
    transition: color 200ms;
  }
  .post-hero-social-btn:nth-child(1):hover { color: #1877F2; text-decoration: none; }
  .post-hero-social-btn:nth-child(2):hover { color: #000000; text-decoration: none; }

  .post-hero-cat {
    display: block;
    font-size: 0.78rem;
    color: var(--color-gold);
    margin-bottom: 0.4rem;
    letter-spacing: 0.02em;
  }

  .post-hero-title {
    font-family: var(--font-display);
    font-size: clamp(1.3rem, 3vw, 2rem);
    font-weight: 700;
    color: var(--color-heading);
    line-height: 1.2;
    margin: 0 0 0.4rem;
  }

  .post-hero-desc {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin: 0 0 0.4rem;
  }

  .post-hero-meta {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  /* ====== POST BODY: share | content | sidebar ====== */
  .post-body-wrap {
    max-width: 1200px;
    margin-inline: auto;
    padding: 2.5rem 1rem 3.5rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: start;
  }

  @media (min-width: 640px) {
    .post-body-wrap { padding-inline: 2rem; }
  }

  @media (min-width: 960px) {
    .post-body-wrap {
      grid-template-columns: 64px 1fr 260px;
      gap: 2rem;
      align-items: start;
    }
  }

  @media (min-width: 960px) {
    .post-sidebar { align-self: stretch; }
  }

  /* Left share panel — hidden on mobile */
  .post-share-col { display: none; }

  @media (min-width: 960px) {
    .post-share-col { display: block; }
  }

  .post-share-sticky {
    position: sticky;
    top: 80px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .post-share-label {
    font-family: var(--font-body);
    font-size: 0.7rem;
    color: var(--color-text-muted);
    letter-spacing: 0.04em;
    margin-bottom: 0.25rem;
  }

  .post-share-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border: 1px solid var(--color-border);
    color: var(--color-heading);
    text-decoration: none;
    background: #fff;
    transition: background-color var(--transition-base), color var(--transition-base), border-color var(--transition-base);
  }

  .post-share-btn:nth-child(2):hover { background: #1877F2; color: #fff; border-color: #1877F2; text-decoration: none; }
  .post-share-btn:nth-child(3):hover { background: #000000; color: #fff; border-color: #000000; text-decoration: none; }

  /* Content */
  .post-content-area { min-width: 0; }

  /* Drop cap — desktop only */
  @media (min-width: 640px) {
    .drop-cap > p:first-child::first-letter {
      font-family: var(--font-display);
      font-size: 4.5rem;
      font-weight: 700;
      line-height: 0.78;
      float: left;
      margin-right: 0.08em;
      margin-top: 0.08em;
      color: var(--color-heading);
    }
  }

  .post-content { margin-top: 0; }

  /* H2 — numbered italic serif, matching screenshot */
  .post-content {
    counter-reset: h2counter;
  }

  .post-content h2 {
    counter-increment: h2counter;
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.5vw, 1.6rem);
    font-weight: 700;
    font-style: italic;
    color: var(--color-heading);
    margin-top: 3rem;
    margin-bottom: 0.75rem;
    display: flex;
    align-items: baseline;
    gap: 0.55rem;
  }

  .post-content h2::before {
    content: "0" counter(h2counter) ".";
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-style: italic;
    font-weight: 400;
    color: var(--color-gold);
    flex-shrink: 0;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--color-gold);
  }

  .post-content h2.active {
    color: var(--color-gold);
    text-decoration: underline;
    text-underline-offset: 5px;
    text-decoration-color: var(--color-gold);
  }

  .post-content p { line-height: 1.8; margin-bottom: 1.25rem; }
  .post-content img { width: 100%; margin-block: 1.5rem; }

  /* ====== TOC SIDEBAR ====== */
  .post-sidebar {
    min-width: 0;
  }

  .toc-sidebar {
    position: sticky;
    top: 90px;
    background: #EEEAE3;
    padding: 1.25rem 1.4rem 0;
  }

  .toc-sidebar-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-heading);
    padding-bottom: 0.85rem;
    border-bottom: 2px solid var(--color-gold);
    margin-bottom: 1rem;
  }

  .toc-sidebar-toggle {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    padding: 0;
    transition: transform 200ms;
  }

  .toc-collapsed { display: none !important; }

  .toc-sidebar-list {
    list-style: decimal;
    padding-left: 1.3rem;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .toc-sidebar-list li {
    padding-block: 0.7rem;
    border-bottom: 1px solid rgba(0,0,0,0.07);
  }
  .toc-sidebar-list li:last-child { border-bottom: none; }

  .toc-sidebar-link {
    font-family: var(--font-body);
    font-size: 0.88rem;
    color: var(--color-text);
    text-decoration: none;
    line-height: 1.4;
    transition: color 200ms;
    display: block;
  }
  .toc-sidebar-link:hover { color: var(--color-gold); text-decoration: none; }
  .toc-sidebar-link.active { color: var(--color-gold); font-weight: 600; }

  .toc-sidebar-footer {
    border-top: 2px solid var(--color-gold);
    margin-top: 1rem;
    padding: 1rem 0 1.25rem;
  }

  .toc-sidebar-footer-label {
    display: block;
    font-family: var(--font-body);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: 0.75rem;
  }

  .toc-sidebar-cats {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .toc-sidebar-cats a {
    font-family: var(--font-body);
    font-size: 0.82rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 200ms;
  }
  .toc-sidebar-cats a:hover { color: var(--color-heading); text-decoration: none; }

  /* ====== RELATED ARTICLES ====== */
  .related-section {
    background: var(--color-surface);
    padding-block: 3.5rem 4rem;
    border-top: 1px solid var(--color-border);
  }

  .related-inner {
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: 1rem;
  }

  @media (min-width: 640px) {
    .related-inner { padding-inline: 2rem; }
  }

  .related-title {
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-heading);
    text-align: center;
    margin-bottom: 2rem;
    padding-bottom: 0.5rem;
    display: inline-block;
    border-bottom: 2px solid var(--color-gold);
    width: 100%;
    text-align: center;
  }

  .related-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 560px) {
    .related-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 900px) {
    .related-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .related-card {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .related-card-img {
    aspect-ratio: 4/3;
    overflow: hidden;
    background: var(--color-border);
  }

  .related-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 400ms ease;
  }

  .related-card:hover .related-card-img img { transform: scale(1.04); }

  .related-card-body {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .related-card-cat {
    font-size: 0.72rem;
    color: var(--color-gold);
  }

  .related-card-title {
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-heading);
    line-height: 1.3;
    transition: color 200ms ease;
  }

  .related-card:hover .related-card-title { color: var(--color-gold); }

  .related-card-meta {
    font-size: 0.7rem;
    color: var(--color-text-muted);
  }

  /* Back to Blog button */
  .related-back {
    text-align: center;
    margin-top: 2.5rem;
  }

  .related-back-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-heading);
    border: 1.5px solid var(--color-border);
    padding: 0.6rem 1.4rem;
    text-decoration: none;
    transition: background-color 200ms, border-color 200ms, color 200ms;
    letter-spacing: 0.02em;
  }

  .related-back-btn:hover {
    background: var(--color-heading);
    border-color: var(--color-heading);
    color: #fff;
    text-decoration: none;
  }

  /* Breadcrumb */
  .breadcrumb {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    align-items: center;
  }
  .breadcrumb a { color: var(--color-text-muted); text-decoration: none; }
  .breadcrumb a:hover { color: var(--color-primary); }
  .breadcrumb-sep { color: var(--color-border); }
</style>
