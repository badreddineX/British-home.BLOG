---
import { getCollection } from 'astro:content';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SEO from '../../components/SEO.astro';
import PostCard from '../../components/PostCard.astro';
import '../../styles/global.css';

const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort(
  (a, b) => new Date(b.data.datePublished).getTime() - new Date(a.data.datePublished).getTime()
);

const url = Astro.url;
const categoryFilter = url.searchParams.get('category') ?? '';

const filteredPosts = categoryFilter
  ? sortedPosts.filter(
      p => p.data.category?.toLowerCase().replace(/\s+/g, '-') === categoryFilter
    )
  : sortedPosts;

const categories = [
  { label: 'All Posts',      slug: '' },
  { label: 'Living Room',    slug: 'living-room' },
  { label: 'Bedroom',        slug: 'bedroom' },
  { label: 'Kitchen',        slug: 'kitchen' },
  { label: 'Room Makeovers', slug: 'room-makeovers' },
];
---

<html lang="en-GB">
  <head>
    <SEO
      title={categoryFilter ? `${categories.find(c => c.slug === categoryFilter)?.label ?? 'Blog'} — British Home Interior` : "Blog — British Home Interior"}
      description="Browse all British home interior styling guides, room makeovers, and cosy decor ideas for UK homes, flats, and Victorian terraces."
      type="website"
    />
  </head>
  <body>
    <Header />

    <main>
      <div class="blog-header container">
        <h1>Interior Inspiration</h1>
        <p class="blog-subtitle">Styling guides, room makeovers, and cosy ideas for UK homes</p>

        <nav class="filter-nav" aria-label="Filter by category">
          {categories.map(cat => (
            <a
              href={cat.slug ? `/blog/?category=${cat.slug}` : '/blog/'}
              class={`filter-pill ${categoryFilter === cat.slug ? 'active' : ''}`}
            >
              {cat.label}
            </a>
          ))}
        </nav>
      </div>

      <div class="container posts-container">
        {filteredPosts.length === 0 ? (
          <p class="no-posts">No posts found in this category yet — check back soon!</p>
        ) : (
          <>
            <div class="posts-grid-2" id="posts-grid">
              {filteredPosts.map((post, i) => (
                <div class="post-item" data-index={i}>
                  <PostCard
                    title={post.data.title}
                    excerpt={post.data.excerpt ?? post.data.description}
                    slug={post.slug}
                    image={post.data.image}
                    category={post.data.category}
                    readTime={post.data.readTime}
                    datePublished={post.data.datePublished}
                  />
                </div>
              ))}
            </div>

            <nav class="pagination" id="pagination" aria-label="Page navigation"></nav>
          </>
        )}
      </div>
    </main>

    <Footer />
  </body>
</html>

<script>
  const PER_PAGE = 6;
  const items = Array.from(document.querySelectorAll<HTMLElement>('.post-item'));
  const total = items.length;
  const pages = Math.ceil(total / PER_PAGE);
  const nav = document.getElementById('pagination');

  function currentPage(): number {
    const p = parseInt(new URLSearchParams(location.search).get('page') ?? '1');
    return Math.max(1, Math.min(p, pages));
  }

  function showPage(page: number) {
    items.forEach((item, i) => {
      item.style.display = (i >= (page - 1) * PER_PAGE && i < page * PER_PAGE) ? '' : 'none';
    });
    renderPagination(page);

    // Update ?page in URL without reloading (keep ?category if present)
    const u = new URL(location.href);
    if (page === 1) {
      u.searchParams.delete('page');
    } else {
      u.searchParams.set('page', String(page));
    }
    history.replaceState({}, '', u.toString());

    // Scroll to top of grid smoothly
    document.getElementById('posts-grid')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function btn(label: string, page: number, active = false, disabled = false, arrow = false): HTMLButtonElement {
    const b = document.createElement('button');
    b.textContent = label;
    b.className = ['page-btn', active ? 'active' : '', disabled ? 'disabled' : '', arrow ? 'arrow-btn' : ''].filter(Boolean).join(' ');
    b.disabled = disabled;
    if (!disabled) b.addEventListener('click', () => showPage(page));
    return b;
  }

  function renderPagination(current: number) {
    if (!nav) return;
    nav.innerHTML = '';
    if (pages <= 1) return;

    nav.appendChild(btn('‹', current - 1, false, current === 1, true));

    for (let p = 1; p <= pages; p++) {
      nav.appendChild(btn(String(p), p, p === current));
    }

    nav.appendChild(btn('›', current + 1, false, current === pages, true));
  }

  // Initialise
  if (pages > 1) {
    showPage(currentPage());
  }
</script>

<style>
  .blog-header {
    padding-block: 3rem 2rem;
    text-align: center;
  }

  .blog-header h1 {
    font-size: 2.2rem;
    margin-bottom: 0.5rem;
  }

  .blog-subtitle {
    color: var(--color-text-muted);
    font-size: 1rem;
    margin-bottom: 1.75rem;
  }

  .filter-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
  }

  .filter-pill {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    padding: 0.4rem 1rem;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: all var(--transition-base);
    background: transparent;
  }

  .filter-pill:hover,
  .filter-pill.active {
    background-color: var(--color-primary);
    border-color: var(--color-primary);
    color: var(--color-white);
    text-decoration: none;
  }

  .posts-container {
    padding-bottom: 5rem;
  }

  .no-posts {
    text-align: center;
    color: var(--color-text-muted);
    padding-block: 3rem;
  }

  /* ====== PAGINATION ====== */
  .pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.15rem;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
    flex-wrap: wrap;
  }

  .page-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 500;
    border: none;
    background: transparent;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: background 180ms, color 180ms;
    letter-spacing: 0;
  }

  .page-btn:hover:not(.disabled):not(.active) {
    color: var(--color-heading);
    background: var(--color-surface);
  }

  /* Active page — dark green filled circle matching the nav */
  .page-btn.active {
    background: var(--color-dark);
    color: #fff;
    cursor: default;
    font-weight: 700;
  }

  /* Arrow buttons — slightly larger glyph, same muted colour */
  .page-btn.arrow-btn {
    font-size: 1.1rem;
    color: rgba(0,0,0,0.3);
  }
  .page-btn.arrow-btn:hover:not(.disabled) {
    background: transparent;
    color: var(--color-heading);
  }

  .page-btn.disabled {
    opacity: 0.25;
    cursor: not-allowed;
  }
</style>
