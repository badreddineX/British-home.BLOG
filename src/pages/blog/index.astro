---
import { getCollection } from 'astro:content';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SEO from '../../components/SEO.astro';
import '../../styles/global.css';

const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort(
  (a, b) => new Date(b.data.datePublished).getTime() - new Date(a.data.datePublished).getTime()
);

// All posts always rendered — category filtering is done client-side
// (static site: Astro.url.searchParams is empty at build time)
const categories = [
  { label: 'All Posts',      slug: '' },
  { label: 'Living Room',    slug: 'living-room' },
  { label: 'Bedroom',        slug: 'bedroom' },
  { label: 'Kitchen',        slug: 'kitchen' },
  { label: 'Room Makeovers', slug: 'room-makeovers' },
];

function fmtDate(d: string) {
  return new Date(d).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
}
---

<html lang="en-GB">
  <head>
    <SEO
      title="Read — British Home Interior"
      description="Browse all British home interior styling guides, room makeovers, and cosy decor ideas for UK homes, flats, and Victorian terraces."
      type="website"
    />
  </head>
  <body>
    <Header />

    <main>

      <!-- ====== FILTER ROW ====== -->
      <div class="bl-filter-bar">
        <nav class="bl-filter-links" aria-label="Filter by category">
          {categories.map(cat => (
            <button
              class="bl-filter-link"
              data-slug={cat.slug}
              type="button"
            >
              {cat.label}
            </button>
          ))}
        </nav>
        <button class="bl-search-btn" aria-label="Search" id="search-toggle">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
        </button>
      </div>

      <!-- ====== SEARCH BAR (hidden by default) ====== -->
      <div class="bl-search-bar" id="search-bar" hidden>
        <input
          type="search"
          id="search-input"
          class="bl-search-input"
          placeholder="Search articles…"
          aria-label="Search articles"
          autocomplete="off"
        />
      </div>

      <!-- ====== POST LIST ====== -->
      <div class="bl-container">
        {sortedPosts.length === 0 ? (
          <p class="no-posts">No posts found in this category yet — check back soon!</p>
        ) : (
          <>
            <div id="posts-grid">
              {sortedPosts.map((post, i) => (
                <div
                  class="post-item"
                  data-index={i}
                  data-title={post.data.title.toLowerCase()}
                  data-excerpt={(post.data.excerpt ?? post.data.description ?? '').toLowerCase()}
                  data-category={post.data.category?.toLowerCase().replace(/\s+/g, '-')}
                >
                  <article class="bl-card">
                    <a href={`/blog/${post.slug}/`} class="bl-card-img-wrap" tabindex="-1" aria-hidden="true">
                      <img
                        src={post.data.image}
                        alt={post.data.title}
                        width="720"
                        height="480"
                        loading="lazy"
                        decoding="async"
                      />
                    </a>
                    <div class="bl-card-body">
                      <div class="bl-card-meta">
                        <span class="bl-avatar" aria-hidden="true">S</span>
                        <span class="bl-author">Sarah</span>
                        <span class="bl-dot" aria-hidden="true">·</span>
                        <time datetime={post.data.datePublished}>{fmtDate(post.data.datePublished)}</time>
                        <span class="bl-dot" aria-hidden="true">·</span>
                        <span>{post.data.readTime ?? '5 min read'}</span>
                      </div>
                      <h2 class="bl-card-title">
                        <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
                      </h2>
                      <p class="bl-card-excerpt">{post.data.excerpt ?? post.data.description}</p>
                      <span class="bl-card-cat">{post.data.category}</span>
                    </div>
                  </article>
                </div>
              ))}
            </div>

            <nav class="pagination" id="pagination" aria-label="Page navigation"></nav>
          </>
        )}
      </div>

    </main>

    <Footer />
  </body>
</html>

<script>
  const PER_PAGE = 6;
  const allItems = Array.from(document.querySelectorAll<HTMLElement>('.post-item'));
  let visibleItems = allItems;
  const paginationNav = document.getElementById('pagination');

  /* ---- Category filter ---- */
  let activeCategory = new URLSearchParams(location.search).get('category') ?? '';

  const filterBtns = Array.from(document.querySelectorAll<HTMLButtonElement>('.bl-filter-link'));

  function setActiveFilterBtn(slug: string) {
    filterBtns.forEach(btn => btn.classList.toggle('active', btn.dataset.slug === slug));
  }

  function applyCategory(slug: string) {
    activeCategory = slug;
    setActiveFilterBtn(slug);

    const u = new URL(location.href);
    slug ? u.searchParams.set('category', slug) : u.searchParams.delete('category');
    u.searchParams.delete('page');
    history.replaceState({}, '', u.toString());

    applyFilters();
  }

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => applyCategory(btn.dataset.slug ?? ''));
  });

  /* ---- Search ---- */
  const searchToggle = document.getElementById('search-toggle');
  const searchBar = document.getElementById('search-bar') as HTMLElement | null;
  const searchInput = document.getElementById('search-input') as HTMLInputElement | null;
  let activeSearch = '';

  searchToggle?.addEventListener('click', () => {
    const hidden = searchBar?.hasAttribute('hidden');
    if (hidden) {
      searchBar?.removeAttribute('hidden');
      searchInput?.focus();
    } else {
      searchBar?.setAttribute('hidden', '');
      if (searchInput) searchInput.value = '';
      activeSearch = '';
      applyFilters();
    }
  });

  searchInput?.addEventListener('input', () => {
    activeSearch = searchInput?.value.trim().toLowerCase() ?? '';
    applyFilters();
  });

  /* ---- Combined filter logic ---- */
  function applyFilters() {
    visibleItems = allItems.filter(item => {
      const catMatch = !activeCategory || item.dataset.category === activeCategory;
      const searchMatch = !activeSearch ||
        (item.dataset.title ?? '').includes(activeSearch) ||
        (item.dataset.excerpt ?? '').includes(activeSearch);
      return catMatch && searchMatch;
    });

    allItems.forEach(item => (item.style.display = 'none'));
    showPage(1);
  }

  /* ---- Pagination ---- */
  function totalPages() { return Math.max(1, Math.ceil(visibleItems.length / PER_PAGE)); }

  function currentPage(): number {
    const p = parseInt(new URLSearchParams(location.search).get('page') ?? '1');
    return Math.max(1, Math.min(p, totalPages()));
  }

  function showPage(page: number) {
    allItems.forEach(item => (item.style.display = 'none'));
    const start = (page - 1) * PER_PAGE;
    visibleItems.slice(start, start + PER_PAGE).forEach(item => (item.style.display = ''));

    // Show "no posts" message if nothing visible
    const noPostsEl = document.querySelector<HTMLElement>('.no-posts-dynamic');
    if (noPostsEl) noPostsEl.style.display = visibleItems.length === 0 ? '' : 'none';

    renderPagination(page);

    const u = new URL(location.href);
    page === 1 ? u.searchParams.delete('page') : u.searchParams.set('page', String(page));
    history.replaceState({}, '', u.toString());
  }

  function btn(label: string, page: number, active = false, disabled = false, arrow = false): HTMLButtonElement {
    const b = document.createElement('button');
    b.textContent = label;
    b.className = ['page-btn', active && 'active', disabled && 'disabled', arrow && 'arrow-btn'].filter(Boolean).join(' ');
    b.disabled = disabled;
    if (!disabled) b.addEventListener('click', () => showPage(page));
    return b;
  }

  function renderPagination(current: number) {
    if (!paginationNav) return;
    paginationNav.innerHTML = '';
    const pages = totalPages();
    if (pages <= 1) return;
    paginationNav.appendChild(btn('‹', current - 1, false, current === 1, true));
    for (let p = 1; p <= pages; p++) paginationNav.appendChild(btn(String(p), p, p === current));
    paginationNav.appendChild(btn('›', current + 1, false, current === pages, true));
  }

  // Init — apply category from URL on load, then paginate
  setActiveFilterBtn(activeCategory);
  applyFilters();
</script>

<style>
  /* ====== FILTER BAR ====== */
  .bl-filter-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1100px;
    margin-inline: auto;
    padding: 1.75rem 2rem 0;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 1.25rem;
  }

  .bl-filter-links {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    flex-wrap: wrap;
  }

  .bl-filter-link {
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 400;
    color: var(--color-text-muted);
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    padding: 0 0 2px;
    cursor: pointer;
    transition: color 200ms;
    white-space: nowrap;
    line-height: 1;
  }

  .bl-filter-link:hover { color: var(--color-heading); }

  .bl-filter-link.active {
    color: var(--color-heading);
    font-weight: 600;
    border-bottom-color: var(--color-heading);
    padding-bottom: 0;
  }

  .bl-search-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text-muted);
    padding: 0.3rem;
    display: flex;
    align-items: center;
    transition: color 200ms;
    flex-shrink: 0;
  }
  .bl-search-btn:hover { color: var(--color-heading); }

  /* ====== SEARCH BAR ====== */
  .bl-search-bar {
    max-width: 1100px;
    margin-inline: auto;
    padding-inline: 2rem;
    padding-block: 1rem;
    border-bottom: 1px solid var(--color-border);
  }

  .bl-search-input {
    width: 100%;
    border: none;
    border-bottom: 1px solid var(--color-border);
    background: transparent;
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: var(--color-heading);
    padding: 0.5rem 0;
    outline: none;
  }
  .bl-search-input::placeholder { color: var(--color-text-muted); font-style: italic; }

  /* ====== POST LIST ====== */
  .bl-container {
    max-width: 1100px;
    margin-inline: auto;
    padding-inline: 2rem;
    padding-bottom: 5rem;
  }

  /* ====== HORIZONTAL CARD ====== */
  .bl-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 300px;
    border-bottom: 1px solid var(--color-border);
  }

  @media (max-width: 680px) {
    .bl-card { grid-template-columns: 1fr; }
  }

  .bl-card-img-wrap {
    display: block;
    overflow: hidden;
    background: var(--color-surface);
  }

  .bl-card-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 500ms ease;
  }
  .bl-card:hover .bl-card-img-wrap img { transform: scale(1.04); }

  /* Body */
  .bl-card-body {
    padding: 2.5rem 2.5rem 2.5rem 3rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.85rem;
  }

  @media (max-width: 680px) {
    .bl-card-body { padding: 1.5rem; }
  }

  /* Meta row */
  .bl-card-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    flex-wrap: wrap;
  }

  .bl-avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  .bl-author { font-weight: 500; color: var(--color-text); }
  .bl-dot { color: var(--color-border); }

  /* Title */
  .bl-card-title {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 2.5vw, 1.65rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--color-heading);
    line-height: 1.2;
    margin: 0;
  }

  .bl-card-title a {
    color: inherit;
    text-decoration: none;
    transition: color 200ms;
  }
  .bl-card-title a:hover { color: var(--color-primary); text-decoration: none; }

  /* Excerpt */
  .bl-card-excerpt {
    font-family: var(--font-body);
    font-size: 0.92rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Category tag */
  .bl-card-cat {
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-top: auto;
  }

  .no-posts {
    text-align: center;
    color: var(--color-text-muted);
    padding-block: 4rem;
    font-style: italic;
  }
</style>
