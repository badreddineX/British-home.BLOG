---
import { getCollection } from 'astro:content';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SEO from '../../components/SEO.astro';
import '../../styles/global.css';

const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort(
  (a, b) => new Date(b.data.datePublished).getTime() - new Date(a.data.datePublished).getTime()
);

// All posts always rendered — category + search filtering done client-side
const categories = [
  { label: 'All Posts',      slug: '' },
  { label: 'Living Room',    slug: 'living-room' },
  { label: 'Bedroom',        slug: 'bedroom' },
  { label: 'Kitchen',        slug: 'kitchen' },
  { label: 'Room Makeovers', slug: 'room-makeovers' },
];

function fmtDate(d: string) {
  return new Date(d).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
}
---

<html lang="en-GB">
  <head>
    <SEO
      title="Read — British Home Interior"
      description="Browse all British home interior styling guides, room makeovers, and cosy decor ideas for UK homes, flats, and Victorian terraces."
      type="website"
    />
  </head>
  <body>
    <Header />

    <!-- ====== SEARCH OVERLAY ====== -->
    <div class="search-overlay" id="search-overlay" aria-modal="true" role="dialog" aria-label="Search articles" hidden>
      <div class="search-overlay-inner">
        <!-- Pill input -->
        <div class="search-pill">
          <svg class="search-pill-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
          <input
            type="search"
            id="search-input"
            class="search-pill-input"
            placeholder="Search articles…"
            aria-label="Search articles"
            autocomplete="off"
          />
          <button class="search-pill-close" id="search-close" aria-label="Close search">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M18 6 6 18M6 6l12 12"/>
            </svg>
          </button>
        </div>

        <!-- Results list -->
        <ul class="search-results" id="search-results" role="listbox" aria-label="Search results"></ul>
        <p class="search-empty" id="search-empty" hidden>No articles match your search.</p>
      </div>
      <!-- Click outside to close -->
      <div class="search-backdrop" id="search-backdrop"></div>
    </div>

    <main>

      <!-- ====== FILTER ROW ====== -->
      <div class="bl-filter-bar">
        <nav class="bl-filter-links" aria-label="Filter by category">
          {categories.map(cat => (
            <button class="bl-filter-link" data-slug={cat.slug} type="button">
              {cat.label}
            </button>
          ))}
        </nav>
        <button class="bl-search-btn" aria-label="Open search" id="search-toggle">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
        </button>
      </div>

      <!-- ====== POST LIST ====== -->
      <div class="bl-container">
        <div id="posts-grid">
          {sortedPosts.map((post, i) => (
            <div
              class="post-item"
              data-index={i}
              data-title={post.data.title.toLowerCase()}
              data-excerpt={(post.data.excerpt ?? post.data.description ?? '').toLowerCase()}
              data-category={post.data.category?.toLowerCase().replace(/\s+/g, '-')}
              data-href={`/blog/${post.slug}/`}
              data-category-label={post.data.category}
            >
              <article class="bl-card">
                <a href={`/blog/${post.slug}/`} class="bl-card-img-wrap" tabindex="-1" aria-hidden="true">
                  <img
                    src={post.data.image}
                    alt={post.data.title}
                    width="720"
                    height="480"
                    loading="lazy"
                    decoding="async"
                  />
                </a>
                <div class="bl-card-body">
                  <div class="bl-card-meta">
                    <span class="bl-avatar" aria-hidden="true">S</span>
                    <span class="bl-author">Sarah</span>
                    <span class="bl-dot" aria-hidden="true">·</span>
                    <time datetime={post.data.datePublished}>{fmtDate(post.data.datePublished)}</time>
                    <span class="bl-dot" aria-hidden="true">·</span>
                    <span>{post.data.readTime ?? '5 min read'}</span>
                  </div>
                  <h2 class="bl-card-title">
                    <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
                  </h2>
                  <p class="bl-card-excerpt">{post.data.excerpt ?? post.data.description}</p>
                  <span class="bl-card-cat">{post.data.category}</span>
                </div>
              </article>
            </div>
          ))}
        </div>

        <p class="no-posts-dynamic" id="no-posts-msg" hidden>No posts found in this category — check back soon!</p>
        <nav class="pagination" id="pagination" aria-label="Page navigation"></nav>
      </div>

    </main>

    <Footer />
  </body>
</html>

<script>
  /* ================================================================
     DATA — collect all post metadata from the DOM once
  ================================================================ */
  const PER_PAGE = 6;
  const allItems = Array.from(document.querySelectorAll<HTMLElement>('.post-item'));
  let visibleItems = allItems;
  const paginationNav = document.getElementById('pagination');
  const noPostsMsg   = document.getElementById('no-posts-msg');

  /* ================================================================
     CATEGORY FILTER
  ================================================================ */
  let activeCategory = new URLSearchParams(location.search).get('category') ?? '';

  const filterBtns = Array.from(document.querySelectorAll<HTMLButtonElement>('.bl-filter-link'));

  function setActiveFilterBtn(slug: string) {
    filterBtns.forEach(b => b.classList.toggle('active', b.dataset.slug === slug));
  }

  function applyCategory(slug: string) {
    activeCategory = slug;
    setActiveFilterBtn(slug);
    const u = new URL(location.href);
    slug ? u.searchParams.set('category', slug) : u.searchParams.delete('category');
    u.searchParams.delete('page');
    history.replaceState({}, '', u.toString());
    applyFilters();
  }

  filterBtns.forEach(b => b.addEventListener('click', () => applyCategory(b.dataset.slug ?? '')));

  /* ================================================================
     SEARCH OVERLAY
  ================================================================ */
  const overlay       = document.getElementById('search-overlay') as HTMLElement;
  const searchInput   = document.getElementById('search-input') as HTMLInputElement;
  const searchResults = document.getElementById('search-results') as HTMLUListElement;
  const searchEmpty   = document.getElementById('search-empty') as HTMLElement;
  const searchToggle  = document.getElementById('search-toggle') as HTMLButtonElement;
  const searchClose   = document.getElementById('search-close') as HTMLButtonElement;
  const backdrop      = document.getElementById('search-backdrop') as HTMLElement;

  function openSearch() {
    overlay.removeAttribute('hidden');
    document.body.style.overflow = 'hidden';
    searchInput.focus();
    renderSearchResults('');
  }

  function closeSearch() {
    overlay.setAttribute('hidden', '');
    document.body.style.overflow = '';
    searchInput.value = '';
  }

  searchToggle.addEventListener('click', openSearch);
  searchClose.addEventListener('click', closeSearch);
  backdrop.addEventListener('click', closeSearch);

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && !overlay.hasAttribute('hidden')) closeSearch();
  });

  function categoryLabel(slug: string): string {
    const map: Record<string, string> = {
      'living-room': 'Living Room',
      'bedroom': 'Bedroom',
      'kitchen': 'Kitchen',
      'room-makeovers': 'Room Makeovers',
    };
    return map[slug] ?? slug;
  }

  function renderSearchResults(query: string) {
    searchResults.innerHTML = '';
    if (!query) {
      searchEmpty.setAttribute('hidden', '');
      return;
    }

    const q = query.toLowerCase();
    const matches = allItems.filter(item =>
      (item.dataset.title ?? '').includes(q) ||
      (item.dataset.excerpt ?? '').includes(q)
    );

    if (matches.length === 0) {
      searchEmpty.removeAttribute('hidden');
      return;
    }
    searchEmpty.setAttribute('hidden', '');

    matches.slice(0, 8).forEach(item => {
      const li = document.createElement('li');
      li.className = 'search-result-item';
      li.setAttribute('role', 'option');

      const catSlug  = item.dataset.category ?? '';
      const catLabel = (item.dataset.categoryLabel ?? categoryLabel(catSlug)).toUpperCase();
      const title    = item.dataset.title ?? '';
      const href     = item.dataset.href ?? '#';

      li.innerHTML = `
        <span class="sr-tag">${catLabel}</span>
        <span class="sr-title">${title.charAt(0).toUpperCase() + title.slice(1)}</span>
      `;
      li.addEventListener('click', () => { location.href = href; });
      searchResults.appendChild(li);
    });
  }

  searchInput.addEventListener('input', () => {
    renderSearchResults(searchInput.value.trim());
  });

  /* ================================================================
     COMBINED FILTER + PAGINATION
  ================================================================ */
  function applyFilters() {
    visibleItems = allItems.filter(item => {
      return !activeCategory || item.dataset.category === activeCategory;
    });
    allItems.forEach(item => (item.style.display = 'none'));
    showPage(1);
  }

  function totalPages() { return Math.max(1, Math.ceil(visibleItems.length / PER_PAGE)); }

  function showPage(page: number) {
    allItems.forEach(item => (item.style.display = 'none'));
    const start = (page - 1) * PER_PAGE;
    visibleItems.slice(start, start + PER_PAGE).forEach(item => (item.style.display = ''));

    if (noPostsMsg) noPostsMsg.hidden = visibleItems.length > 0;

    renderPagination(page);

    const u = new URL(location.href);
    page === 1 ? u.searchParams.delete('page') : u.searchParams.set('page', String(page));
    history.replaceState({}, '', u.toString());
  }

  function mkBtn(label: string, page: number, active = false, disabled = false, arrow = false): HTMLButtonElement {
    const b = document.createElement('button');
    b.textContent = label;
    b.className = ['page-btn', active && 'active', disabled && 'disabled', arrow && 'arrow-btn'].filter(Boolean).join(' ');
    b.disabled = disabled;
    if (!disabled) b.addEventListener('click', () => showPage(page));
    return b;
  }

  function renderPagination(current: number) {
    if (!paginationNav) return;
    paginationNav.innerHTML = '';
    const pages = totalPages();
    if (pages <= 1) return;
    paginationNav.appendChild(mkBtn('‹', current - 1, false, current === 1, true));
    for (let p = 1; p <= pages; p++) paginationNav.appendChild(mkBtn(String(p), p, p === current));
    paginationNav.appendChild(mkBtn('›', current + 1, false, current === pages, true));
  }

  // Init
  setActiveFilterBtn(activeCategory);
  applyFilters();
</script>

<style>
  /* ================================================================
     SEARCH OVERLAY
  ================================================================ */
  .search-overlay {
    position: fixed;
    inset: 0;
    z-index: 9000;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 6rem;
    padding-inline: 1.5rem;
  }

  .search-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
    backdrop-filter: blur(3px);
  }

  .search-overlay-inner {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 660px;
  }

  /* Pill input */
  .search-pill {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    background: #fff;
    border-radius: 9999px;
    padding: 0.75rem 1rem 0.75rem 1.25rem;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.22);
  }

  .search-pill-icon {
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  .search-pill-input {
    flex: 1;
    border: none;
    outline: none;
    background: transparent;
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-heading);
  }
  .search-pill-input::placeholder { color: var(--color-text-muted); }

  /* Remove default search × in webkit */
  .search-pill-input::-webkit-search-cancel-button { display: none; }

  .search-pill-close {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    padding: 0.2rem;
    border-radius: 50%;
    transition: color 150ms, background 150ms;
    flex-shrink: 0;
  }
  .search-pill-close:hover { color: var(--color-heading); background: var(--color-surface); }

  /* Results list */
  .search-results {
    list-style: none;
    margin: 0.5rem 0 0;
    padding: 0;
    background: #fff;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.16);
  }

  .search-result-item {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.9rem 1.25rem;
    border-bottom: 1px solid var(--color-border);
    cursor: pointer;
    transition: background 150ms;
  }
  .search-result-item:last-child { border-bottom: none; }
  .search-result-item:hover { background: var(--color-surface); }

  .sr-tag {
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    border-radius: 9999px;
    padding: 0.2rem 0.6rem;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .sr-title {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--color-heading);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .search-empty {
    text-align: center;
    padding: 1.25rem;
    background: #fff;
    border-radius: 16px;
    margin-top: 0.5rem;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    font-style: italic;
    box-shadow: 0 4px 20px rgba(0,0,0,0.10);
  }

  /* ================================================================
     FILTER BAR
  ================================================================ */
  .bl-filter-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1100px;
    margin-inline: auto;
    padding: 1.75rem 2rem 1.25rem;
    border-bottom: 1px solid var(--color-border);
  }

  .bl-filter-links {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    flex-wrap: wrap;
  }

  .bl-filter-link {
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 400;
    color: var(--color-text-muted);
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    padding: 0 0 2px;
    cursor: pointer;
    transition: color 200ms;
    white-space: nowrap;
    line-height: 1;
  }
  .bl-filter-link:hover { color: var(--color-heading); }
  .bl-filter-link.active {
    color: var(--color-heading);
    font-weight: 600;
    border-bottom-color: var(--color-heading);
    padding-bottom: 0;
  }

  .bl-search-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text-muted);
    padding: 0.3rem;
    display: flex;
    align-items: center;
    transition: color 200ms;
    flex-shrink: 0;
  }
  .bl-search-btn:hover { color: var(--color-heading); }

  /* ================================================================
     POST LIST
  ================================================================ */
  .bl-container {
    max-width: 1100px;
    margin-inline: auto;
    padding-inline: 2rem;
    padding-bottom: 5rem;
  }

  /* ================================================================
     HORIZONTAL CARD
  ================================================================ */
  .bl-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 300px;
    border-bottom: 1px solid var(--color-border);
  }

  @media (max-width: 680px) {
    .bl-card { grid-template-columns: 1fr; }
  }

  .bl-card-img-wrap {
    display: block;
    overflow: hidden;
    background: var(--color-surface);
  }

  .bl-card-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 500ms ease;
  }
  .bl-card:hover .bl-card-img-wrap img { transform: scale(1.04); }

  .bl-card-body {
    padding: 2.5rem 2.5rem 2.5rem 3rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.85rem;
  }

  @media (max-width: 680px) {
    .bl-card-body { padding: 1.5rem; }
  }

  .bl-card-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    flex-wrap: wrap;
  }

  .bl-avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  .bl-author { font-weight: 500; color: var(--color-text); }
  .bl-dot { color: var(--color-border); }

  .bl-card-title {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 2.5vw, 1.65rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--color-heading);
    line-height: 1.2;
    margin: 0;
  }

  .bl-card-title a {
    color: inherit;
    text-decoration: none;
    transition: color 200ms;
  }
  .bl-card-title a:hover { color: var(--color-primary); text-decoration: none; }

  .bl-card-excerpt {
    font-family: var(--font-body);
    font-size: 0.92rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .bl-card-cat {
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-top: auto;
  }

  .no-posts-dynamic {
    text-align: center;
    color: var(--color-text-muted);
    padding-block: 4rem;
    font-style: italic;
  }
</style>
