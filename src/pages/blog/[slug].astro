---
import { getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const postSlug = post.id;

const faqs = post.data.faqs.length > 0
  ? post.data.faqs
  : [
      {
        q: `What are the best styling ideas for a ${post.data.category ?? 'UK home'} in Britain?`,
        a: "Focus on layering textures — linen, velvet, and rattan work particularly well in British interiors. Choose a warm neutral base and add one or two accent colours through cushions, throws, and accessories.",
      },
      {
        q: "How do I style a small flat on a budget in the UK?",
        a: "Use mirrors to add depth, shop Dunelm and Next Home for affordable statement pieces, and focus on one feature wall. A budget room makeover is very achievable under £200 with the right priorities.",
      },
      {
        q: "Which UK retailers have the best home decor on a budget?",
        a: "Dunelm is brilliant for soft furnishings and lighting. IKEA UK for storage and basics. Next Home for curtains and rugs. Wayfair UK for larger pieces when they're on sale.",
      },
      {
        q: "Can I redecorate a rented flat without losing my deposit?",
        a: "Yes — use removable wallpaper, freestanding furniture, peel-and-stick tiles, and command hooks. Always check your tenancy agreement before making any permanent changes.",
      },
    ];

const tldr = post.data.tldr.length > 0
  ? post.data.tldr
  : post.data.excerpt
    ? [post.data.excerpt]
    : [
        `Practical ${post.data.category ?? 'interior'} ideas for UK homes`,
        "All budgets covered — from under £50 to investment pieces",
        "UK retailers only — Dunelm, John Lewis, IKEA, Next Home",
      ];
---

<BlogPost
  title={post.data.title}
  description={post.data.description}
  slug={postSlug}
  image={post.data.image}
  datePublished={post.data.datePublished}
  dateModified={post.data.dateModified}
  author={post.data.author}
  category={post.data.category}
  readTime={post.data.readTime}
  tldr={tldr}
  faqs={faqs}
  headings={headings}
>
  <Content />
</BlogPost>
