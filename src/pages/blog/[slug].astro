---
import { getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const postSlug = post.id;

// Only use frontmatter-defined FAQs/TL;DR — falling back to identical generic
// copy on every post that lacks them would emit duplicate FAQPage JSON-LD
// across pages, which is a duplicate-content signal to Google.
const faqs = post.data.faqs;

const tldr = post.data.tldr.length > 0
  ? post.data.tldr
  : post.data.excerpt
    ? [post.data.excerpt]
    : [];
---

<BlogPost
  title={post.data.title}
  description={post.data.description}
  slug={postSlug}
  image={post.data.image}
  datePublished={post.data.datePublished}
  dateModified={post.data.dateModified}
  author={post.data.author}
  category={post.data.category}
  readTime={post.data.readTime}
  tldr={tldr}
  faqs={faqs}
  headings={headings}
>
  <Content />
</BlogPost>
