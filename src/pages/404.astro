---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';
import '../styles/global.css';
---

<html lang="en-GB">
  <head>
    <SEO
      title="Page Not Found — British Home Interior"
      description="This page doesn't exist, but we have plenty of home styling ideas waiting for you."
      canonicalPath="/404/"
    />
  </head>
  <body>
    <Header />

    <main class="not-found">
      <div class="not-found-inner">
        <span class="not-found-num">404</span>
        <h1 class="not-found-heading">We've lost this room</h1>
        <p class="not-found-desc">
          The page you're looking for has moved, been renamed, or never existed —
          a bit like that drawer in the kitchen that somehow swallows everything.
        </p>
        <div class="not-found-actions">
          <a href="/" class="not-found-btn not-found-btn--primary">Back to Home</a>
          <a href="/blog/" class="not-found-btn not-found-btn--outline">Browse All Articles</a>
        </div>
      </div>
    </main>

    <Footer />
  </body>
</html>

<style>
  .not-found {
    background: var(--color-bg);
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 2rem;
  }

  .not-found-inner {
    text-align: center;
    max-width: 520px;
  }

  .not-found-num {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(5rem, 15vw, 9rem);
    font-weight: 700;
    font-style: italic;
    color: var(--color-gold);
    line-height: 1;
    margin-bottom: 0.5rem;
    opacity: 0.35;
  }

  .not-found-heading {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    color: var(--color-heading);
    margin: 0 0 1rem;
  }

  .not-found-desc {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-text-muted);
    margin: 0 0 2.5rem;
  }

  .not-found-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .not-found-btn {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 0.85rem 1.75rem;
    transition: background 200ms, color 200ms, border-color 200ms;
  }

  .not-found-btn--primary {
    background: var(--color-gold);
    color: #fff;
    border: 1px solid var(--color-gold);
  }
  .not-found-btn--primary:hover { background: #9a7f52; border-color: #9a7f52; }

  .not-found-btn--outline {
    background: transparent;
    color: var(--color-heading);
    border: 1px solid var(--color-border);
  }
  .not-found-btn--outline:hover { border-color: var(--color-heading); }
</style>
