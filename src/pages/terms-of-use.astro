    </main>

    <Footer />
  </body>
</html>

<style>
  .policy-main {
    background: var(--color-bg, #FAF7F4);
    padding-block: 4rem 6rem;
  }

  .policy-inner {
    max-width: 760px;
    margin-inline: auto;
    padding-inline: 1.5rem;
  }

  .policy-inner h1 {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 700;
    color: var(--color-heading);
    margin-bottom: 0.5rem;
  }

  .policy-updated {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    margin-bottom: 2.5rem;
  }

  .policy-inner h2 {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-heading);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    border-left: 3px solid var(--color-gold, #B89A6A);
    padding-left: 0.75rem;
  }

  .policy-inner p { line-height: 1.8; margin-bottom: 1rem; font-size: 0.95rem; }

  .policy-inner ul {
    padding-left: 1.4rem;
    margin-bottom: 1rem;
  }

  .policy-inner li {
    font-size: 0.95rem;
    line-height: 1.75;
    margin-bottom: 0.4rem;
  }

  .policy-inner a {
    color: var(--color-gold, #B89A6A);
    text-underline-offset: 2px;
  }
</style>
