---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';
import '../styles/global.css';
---

<html lang="en-GB">
  <head>
    <SEO
      title="About — British Home Interior"
      description="Meet the person behind British Home Interior — a UK home enthusiast sharing honest room makeovers, cosy styling ideas, and budget interior inspiration for British homes and flats."
      type="website"
    />
  </head>
  <body>
    <Header />

    <main class="about-page content-container">
      <!-- ===== AUTHOR HERO ===== -->
      <section class="about-hero">
        <div class="author-avatar">
          <img
            src="/images/author-photo.jpg"
            alt="Blog author — British home interior enthusiast"
            width="150"
            height="150"
          />
        </div>
        <h1 class="about-name">Hello, I'm Sarah</h1>
        <p class="about-tagline">Making British homes cosier, one room at a time.</p>
      </section>

      <hr />

      <!-- ===== WHY I STARTED ===== -->
      <section class="about-section" aria-labelledby="why-heading">
        <h2 id="why-heading">Why I Started This Blog</h2>
        <p>
          I've always loved interiors. But every time I searched for home styling advice online, I found
          American content — dollars instead of pounds, stores that don't ship to the UK, and aesthetics
          built for open-plan Californian homes rather than Victorian terraces and rented London flats.
        </p>
        <p>
          So I decided to create the resource I wished had existed when I was trying to style my first
          flat on a graduate salary. Everything you'll find here is rooted in the reality of British
          homes: the odd proportions, the period features, the renting restrictions, and yes — the grey
          British light that makes colour choices so tricky.
        </p>
        <p>
          I'm not an interior designer. I'm just someone who genuinely loves making a space feel like
          home, and who's spent far too many Saturdays wandering around Dunelm and debating whether
          the terracotta cushion is "investment piece" or "impulse buy." (It was both. I regret nothing.)
        </p>
      </section>

      <hr />

      <!-- ===== WHAT YOU'LL FIND ===== -->
      <section class="about-section" aria-labelledby="find-heading">
        <h2 id="find-heading">What You'll Find Here</h2>
        <div class="feature-cards">
          <div class="feature-card">
            <span class="feature-icon" aria-hidden="true">🎨</span>
            <h3>Room Makeovers</h3>
            <p>
              Real before-and-afters from real British homes. No staging, no professional photography —
              just honest transformations and what I actually spent.
            </p>
          </div>
          <div class="feature-card">
            <span class="feature-icon" aria-hidden="true">💷</span>
            <h3>Budget Styling</h3>
            <p>
              Every tip and product recommendation is budget-aware. I'll always tell you where to find
              something cheaper, and I shop Dunelm, Next Home, and IKEA just like you do.
            </p>
          </div>
          <div class="feature-card">
            <span class="feature-icon" aria-hidden="true">🏡</span>
            <h3>British Home Inspiration</h3>
            <p>
              Cottagecore, maximalist, dark and moody, cosy minimalist — all filtered through a
              British lens, for British homes, in British English.
            </p>
          </div>
        </div>
      </section>

      <hr />

      <!-- ===== LET'S CONNECT ===== -->
      <section class="about-section about-connect" aria-labelledby="connect-heading">
        <h2 id="connect-heading">Let's Connect</h2>
        <p>
          I'd love to see what you're working on. Come and find me on Pinterest where I share daily
          styling inspiration, or drop me an email if you have a question or just want to chat about
          paint colours.
        </p>
        <div class="connect-links">
          <a
            href="https://pinterest.co.uk"
            class="connect-btn connect-pinterest"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Follow on Pinterest (opens in new tab)"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/>
            </svg>
            Follow on Pinterest
          </a>
          <a
            href="mailto:hello@britishhomeinterior.co.uk"
            class="connect-btn connect-email"
            aria-label="Send an email"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <rect x="2" y="4" width="20" height="16" rx="2"/>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
            Send an Email
          </a>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
  .about-page {
    padding-block: 3rem 5rem;
  }

  /* Author Hero */
  .about-hero {
    text-align: center;
    padding-bottom: 2.5rem;
  }

  .author-avatar {
    margin-inline: auto;
    margin-bottom: 1.25rem;
    width: 150px;
    height: 150px;
    border-radius: 50%;
    overflow: hidden;
    border: 4px solid var(--color-surface);
    box-shadow: 0 4px 20px rgba(61, 43, 31, 0.12);
  }

  .author-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .about-name {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .about-tagline {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    font-style: italic;
    margin-bottom: 0;
  }

  /* Sections */
  .about-section {
    padding-block: 2.5rem;
  }

  .about-section h2 {
    margin-top: 0;
  }

  .about-section p:last-child {
    margin-bottom: 0;
  }

  /* Feature Cards */
  .feature-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    margin-top: 1.75rem;
  }

  @media (min-width: 640px) {
    .feature-cards {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .feature-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.5rem 1.25rem;
    text-align: center;
  }

  .feature-icon {
    font-size: 2rem;
    display: block;
    margin-bottom: 0.75rem;
  }

  .feature-card h3 {
    font-family: var(--font-display);
    font-size: 1.05rem;
    color: var(--color-heading);
    margin-top: 0;
    margin-bottom: 0.6rem;
  }

  .feature-card p {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: 0;
  }

  /* Connect */
  .about-connect p {
    margin-bottom: 1.5rem;
  }

  .connect-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .connect-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 700;
    padding: 0.7rem 1.5rem;
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: background-color var(--transition-base), transform var(--transition-base);
  }

  .connect-btn:hover {
    text-decoration: none;
    transform: translateY(-1px);
  }

  .connect-pinterest {
    background-color: #E60023;
    color: #fff;
  }

  .connect-pinterest:hover {
    background-color: #ad081b;
    color: #fff;
  }

  .connect-email {
    background-color: var(--color-surface);
    border: 2px solid var(--color-border);
    color: var(--color-heading);
  }

  .connect-email:hover {
    background-color: var(--color-primary);
    border-color: var(--color-primary);
    color: #fff;
  }
</style>
