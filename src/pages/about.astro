---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';
import '../styles/global.css';
---

<html lang="en-GB">
  <head>
    <SEO
      title="About — British Home Interior"
      description="Meet the person behind British Home Interior — a UK home enthusiast sharing honest room makeovers, cosy styling ideas, and budget interior inspiration for British homes and flats."
      type="website"
    />
  </head>
  <body>
    <Header />

    <main class="about-page content-container">

      <!-- ===== AUTHOR HERO — animates in immediately ===== -->
      <section class="about-hero blur-reveal">
        <div class="author-avatar">
          <img
            src="https://images.pexels.com/photos/3771839/pexels-photo-3771839.jpeg?auto=compress&cs=tinysrgb&w=300&h=300&fit=crop"
            alt="Sarah — British home interior enthusiast"
            width="150"
            height="150"
          />
        </div>
        <h1 class="about-name">Hello, I'm Sarah</h1>
        <p class="about-tagline">Making British homes cosier, one room at a time.</p>
      </section>

      <hr class="blur-reveal" />

      <!-- ===== WHY I STARTED ===== -->
      <section class="about-section blur-reveal" aria-labelledby="why-heading">
        <h2 id="why-heading">Why I Started This Blog</h2>
        <p>
          I've always loved interiors. But every time I searched for home styling advice online, I found
          American content — dollars instead of pounds, stores that don't ship to the UK, and aesthetics
          built for open-plan Californian homes rather than Victorian terraces and rented London flats.
        </p>
        <p>
          So I decided to create the resource I wished had existed when I was trying to style my first
          flat on a graduate salary. Everything you'll find here is rooted in the reality of British
          homes: the odd proportions, the period features, the renting restrictions, and yes — the grey
          British light that makes colour choices so tricky.
        </p>
        <p>
          I'm not an interior designer. I'm just someone who genuinely loves making a space feel like
          home, and who's spent far too many Saturdays wandering around Dunelm and debating whether
          the terracotta cushion is "investment piece" or "impulse buy." (It was both. I regret nothing.)
        </p>
      </section>

      <hr class="blur-reveal" />

      <!-- ===== WHAT YOU'LL FIND ===== -->
      <section class="about-section blur-reveal" aria-labelledby="find-heading">
        <h2 id="find-heading">What You'll Find Here</h2>
        <div class="feature-cards">
          <div class="feature-card">
            <span class="feature-icon" aria-hidden="true">🎨</span>
            <h3>Room Makeovers</h3>
            <p>
              Real before-and-afters from real British homes. No staging, no professional photography —
              just honest transformations and what I actually spent.
            </p>
          </div>
          <div class="feature-card">
            <span class="feature-icon" aria-hidden="true">💷</span>
            <h3>Budget Styling</h3>
            <p>
              Every tip and product recommendation is budget-aware. I'll always tell you where to find
              something cheaper, and I shop Dunelm, Next Home, and IKEA just like you do.
            </p>
          </div>
          <div class="feature-card">
            <span class="feature-icon" aria-hidden="true">🏡</span>
            <h3>British Home Inspiration</h3>
            <p>
              Cottagecore, maximalist, dark and moody, cosy minimalist — all filtered through a
              British lens, for British homes, in British English.
            </p>
          </div>
        </div>
      </section>

    </main>

    <Footer />
  </body>
</html>

<script>
  // Blur-to-focus reveal on scroll
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('in-view');
          observer.unobserve(entry.target); // fire once
        }
      });
    },
    { threshold: 0.08 }
  );

  document.querySelectorAll('.blur-reveal').forEach((el) => observer.observe(el));
</script>

<style>
  /* ===== BLUR REVEAL ANIMATION ===== */
  .blur-reveal {
    filter: blur(18px);
    opacity: 0;
    transform: scale(1.015);
    transition:
      filter 700ms ease,
      opacity 700ms ease,
      transform 700ms ease;
    will-change: filter, opacity, transform;
  }

  .blur-reveal.in-view {
    filter: blur(0);
    opacity: 1;
    transform: scale(1);
  }

  /* Stagger sections slightly */
  .about-section.blur-reveal { transition-delay: 80ms; }
  .feature-cards .feature-card { transition-delay: 0ms; }

  /* Respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .blur-reveal {
      filter: none;
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  /* ===== PAGE LAYOUT ===== */
  .about-page {
    padding-block: 3rem 5rem;
  }

  .about-hero {
    text-align: center;
    padding-bottom: 2.5rem;
  }

  .author-avatar {
    margin-inline: auto;
    margin-bottom: 1.25rem;
    width: 150px;
    height: 150px;
    border-radius: 50%;
    overflow: hidden;
    border: 4px solid var(--color-surface);
    box-shadow: 0 4px 20px rgba(0,0,0,0.12);
  }

  .author-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .about-name {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .about-tagline {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    font-style: italic;
    margin-bottom: 0;
  }

  .about-section {
    padding-block: 2.5rem;
  }

  .about-section h2 {
    margin-top: 0;
  }

  .about-section p:last-child {
    margin-bottom: 0;
  }

  .feature-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    margin-top: 1.75rem;
  }

  @media (min-width: 640px) {
    .feature-cards { grid-template-columns: repeat(3, 1fr); }
  }

  .feature-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    padding: 1.5rem 1.25rem;
    text-align: center;
  }

  .feature-icon {
    font-size: 2rem;
    display: block;
    margin-bottom: 0.75rem;
  }

  .feature-card h3 {
    font-family: var(--font-display);
    font-size: 1.05rem;
    color: var(--color-heading);
    margin-top: 0;
    margin-bottom: 0.6rem;
  }

  .feature-card p {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: 0;
  }
</style>
