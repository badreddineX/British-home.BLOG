---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';
import '../styles/global.css';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const sorted = allPosts.sort(
  (a, b) => new Date(b.data.datePublished).getTime() - new Date(a.data.datePublished).getTime()
);

const featured = sorted[0];
const recent   = sorted.slice(1, 4);

const livingRoom = sorted.filter(p => p.data.category?.toLowerCase().includes('living')).slice(0, 2);
const bedroom    = sorted.filter(p => p.data.category?.toLowerCase().includes('bedroom')).slice(0, 2);
const kitchen    = sorted.filter(p => p.data.category?.toLowerCase().includes('kitchen')).slice(0, 2);
const makeovers  = sorted.filter(p => p.data.category?.toLowerCase().includes('makeover')).slice(0, 2);

const fallback = sorted.slice(0, 2);
const col1 = livingRoom.length ? livingRoom : fallback;
const col2 = bedroom.length    ? bedroom    : fallback;
const col3 = kitchen.length    ? kitchen    : fallback;
const col4 = makeovers.length  ? makeovers  : fallback;

function fmtDate(d: string) {
  return new Date(d).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
}
---

<html lang="en-GB">
  <head>
    <SEO
      title="British Home Interior — Cosy Styling & Room Makeovers for UK Homes"
      description="Home styling inspiration, room makeovers, and cosy interior ideas for UK homes, flats, and Victorian terraces. In British English, in pounds."
      type="website"
      canonicalPath="/"
    />
  </head>
  <body>
    <Header />

    <main>

      <!-- ====== HERO VIDEO ====== -->
      <section
        class="hero"
        aria-label="Welcome"
        style={featured ? `--hero-bg: url('${featured.data.image}')` : ''}
      >
        <div class="hero-media">
          <video
            class="hero-video"
            autoplay
            muted
            loop
            playsinline
            poster={featured?.data.image ?? ''}
          >
            <!-- Free living room video from Pexels CDN -->
            <source src="https://videos.pexels.com/video-files/5644364/5644364-hd_1920_1080_25fps.mp4" type="video/mp4" />
            <source src="https://assets.mixkit.co/videos/preview/mixkit-interior-of-a-living-room-at-night-5823707-large.mp4" type="video/mp4" />
          </video>
          <div class="hero-overlay"></div>
        </div>

        <!-- Welcome card — left side -->
        <div class="hero-card">
          <div class="hero-avatar">
            <svg viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg" width="70" height="70">
              <circle cx="18" cy="18" r="17" stroke="rgba(255,255,255,0.6)" stroke-width="1.2"/>
              <path d="M7 21 L18 10 L29 21" stroke="#fff" stroke-width="1.5" fill="none"/>
              <rect x="12" y="21" width="5" height="6" stroke="#fff" stroke-width="1.2" fill="none"/>
              <rect x="19" y="21" width="5" height="6" stroke="#fff" stroke-width="1.2" fill="none"/>
              <path d="M5 26 Q18 19 31 26" stroke="rgba(255,255,255,0.5)" stroke-width="1" fill="none"/>
            </svg>
          </div>
          <h1 class="hero-welcome">Welcome!</h1>
          <p class="hero-tagline">Your cosy corner of British home styling</p>
          <a href="/blog/" class="hero-cta">Explore the Blog</a>
        </div>
      </section>

      <!-- ====== FEATURED POST (dark bg) ====== -->
      {featured && (
        <section class="featured-section" aria-label="Featured post">
          <div class="featured-inner">
            <h2 class="featured-label">Featured Post</h2>
            <div class="featured-card">
              <a href={`/blog/${featured.slug}/`} class="featured-img-wrap img-wrap">
                <img
                  src={featured.data.image}
                  alt={featured.data.title}
                  width="620"
                  height="420"
                  loading="lazy"
                  decoding="async"
                />
              </a>
              <div class="featured-body">
                <p class="featured-meta">
                  <time datetime={featured.data.datePublished}>{fmtDate(featured.data.datePublished)}</time>
                  &nbsp;·&nbsp;{featured.data.readTime ?? '5 min read'}
                </p>
                <a href={`/blog/${featured.slug}/`} class="featured-title-link">
                  <h3 class="featured-title">{featured.data.title}</h3>
                </a>
                <p class="featured-excerpt">{featured.data.excerpt ?? featured.data.description}</p>
                <a href={`/blog/${featured.slug}/`} class="featured-read">Read More →</a>
              </div>
            </div>
          </div>
        </section>
      )}

      <!-- ====== RECENT POSTS (white bg, 3-col) ====== -->
      <section class="recent-section" aria-label="Recent posts">
        <div class="recent-inner">
          <h2 class="recent-label">Recent Posts</h2>
          <div class="recent-grid">
            {(recent.length ? recent : sorted.slice(0, 3)).map(post => (
              <a href={`/blog/${post.slug}/`} class="recent-card">
                {post.data.image && (
                  <div class="recent-card-img img-wrap">
                    <img
                      src={post.data.image}
                      alt={post.data.title}
                      width="400"
                      height="260"
                      loading="lazy"
                      decoding="async"
                    />
                  </div>
                )}
                <div class="recent-card-body">
                  <span class="recent-card-cat">{post.data.category ?? 'Interiors'}</span>
                  <h3 class="recent-card-title">{post.data.title}</h3>
                  <p class="recent-card-excerpt">{post.data.excerpt ?? post.data.description}</p>
                  <hr class="recent-card-hr" />
                  <span class="recent-card-meta">
                    <time datetime={post.data.datePublished}>{fmtDate(post.data.datePublished)}</time>
                    &nbsp;·&nbsp;{post.data.readTime ?? '5 min read'}
                  </span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>

      <!-- ====== STATS BAR (gold bg) ====== -->
      <div class="stats-bar" aria-label="About us in numbers">
        <div class="stats-inner">
          <div class="stat-item">
            <span class="stat-num">200+</span>
            <span class="stat-label">Styling Tips</span>
          </div>
          <div class="stat-item">
            <span class="stat-num">4</span>
            <span class="stat-label">Room Categories</span>
          </div>
          <div class="stat-item">
            <span class="stat-num">50+</span>
            <span class="stat-label">UK Retailers</span>
          </div>
          <div class="stat-item">
            <span class="stat-num">100%</span>
            <span class="stat-label">British English</span>
          </div>
        </div>
      </div>

      <!-- ====== CATEGORY COLUMNS (2×2 h-cards) ====== -->
      <div class="page-wrap">

        <section class="cat-row" aria-label="Living Room and Bedroom">
          <div class="cat-col">
            <h2 class="cat-section-label">Living Room</h2>
            {col1.map(post => (
              <a href={`/blog/${post.slug}/`} class="h-card">
                <div class="h-card-thumb">
                  <img src={post.data.image} alt={post.data.title} width="200" height="160" loading="lazy" decoding="async" />
                </div>
                <div class="h-card-body">
                  <span class="h-card-cat">{post.data.category ?? 'Interiors'}</span>
                  <span class="h-card-title">{post.data.title}</span>
                  <span class="h-card-meta"><time datetime={post.data.datePublished}>{fmtDate(post.data.datePublished)}</time>&nbsp;·&nbsp;{post.data.readTime ?? '5 min read'}</span>
                  <p class="h-card-excerpt">{post.data.excerpt ?? post.data.description}</p>
                </div>
              </a>
            ))}
          </div>
          <div class="cat-col-divider" aria-hidden="true"></div>
          <div class="cat-col">
            <h2 class="cat-section-label">Bedroom</h2>
            {col2.map(post => (
              <a href={`/blog/${post.slug}/`} class="h-card">
                <div class="h-card-thumb img-wrap">
                  <img src={post.data.image} alt={post.data.title} width="200" height="160" loading="lazy" decoding="async" />
                </div>
                <div class="h-card-body">
                  <span class="h-card-cat">{post.data.category ?? 'Interiors'}</span>
                  <span class="h-card-title">{post.data.title}</span>
                  <span class="h-card-meta"><time datetime={post.data.datePublished}>{fmtDate(post.data.datePublished)}</time>&nbsp;·&nbsp;{post.data.readTime ?? '5 min read'}</span>
                  <p class="h-card-excerpt">{post.data.excerpt ?? post.data.description}</p>
                </div>
              </a>
            ))}
          </div>
        </section>

        <hr class="section-hr" />

        <section class="cat-row" aria-label="Kitchen and Room Makeovers">
          <div class="cat-col">
            <h2 class="cat-section-label">Kitchen</h2>
            {col3.map(post => (
              <a href={`/blog/${post.slug}/`} class="h-card">
                <div class="h-card-thumb img-wrap">
                  <img src={post.data.image} alt={post.data.title} width="200" height="160" loading="lazy" decoding="async" />
                </div>
                <div class="h-card-body">
                  <span class="h-card-cat">{post.data.category ?? 'Interiors'}</span>
                  <span class="h-card-title">{post.data.title}</span>
                  <span class="h-card-meta"><time datetime={post.data.datePublished}>{fmtDate(post.data.datePublished)}</time>&nbsp;·&nbsp;{post.data.readTime ?? '5 min read'}</span>
                  <p class="h-card-excerpt">{post.data.excerpt ?? post.data.description}</p>
                </div>
              </a>
            ))}
          </div>
          <div class="cat-col-divider" aria-hidden="true"></div>
          <div class="cat-col">
            <h2 class="cat-section-label">Room Makeovers</h2>
            {col4.map(post => (
              <a href={`/blog/${post.slug}/`} class="h-card">
                <div class="h-card-thumb img-wrap">
                  <img src={post.data.image} alt={post.data.title} width="200" height="160" loading="lazy" decoding="async" />
                </div>
                <div class="h-card-body">
                  <span class="h-card-cat">{post.data.category ?? 'Interiors'}</span>
                  <span class="h-card-title">{post.data.title}</span>
                  <span class="h-card-meta"><time datetime={post.data.datePublished}>{fmtDate(post.data.datePublished)}</time>&nbsp;·&nbsp;{post.data.readTime ?? '5 min read'}</span>
                  <p class="h-card-excerpt">{post.data.excerpt ?? post.data.description}</p>
                </div>
              </a>
            ))}
          </div>
        </section>

        <div class="all-blogs-wrap">
          <a href="/blog/" class="all-blogs-btn">View All Blogs</a>
        </div>
      </div>

      <!-- ====== MOOD BOARD ANIMATION ====== -->
      <section class="mood-section" aria-label="Interior inspiration">

        <!-- Scrolling background text -->
        <div class="mood-marquee" aria-hidden="true">
          <div class="mood-marquee-inner">
            <span>LIVING ROOM</span><span class="mood-dot"> · </span>
            <span>BEDROOM</span><span class="mood-dot"> · </span>
            <span>KITCHEN</span><span class="mood-dot"> · </span>
            <span>ROOM MAKEOVERS</span><span class="mood-dot"> · </span>
            <span>LIVING ROOM</span><span class="mood-dot"> · </span>
            <span>BEDROOM</span><span class="mood-dot"> · </span>
            <span>KITCHEN</span><span class="mood-dot"> · </span>
            <span>ROOM MAKEOVERS</span><span class="mood-dot"> · </span>
          </div>
        </div>

        <!-- Floating collage -->
        <div class="mood-stage">

          <!-- Photo A — left, tilted left -->
          <div class="mood-photo mood-photo-a">
            <img src="https://images.pexels.com/photos/1571460/pexels-photo-1571460.jpeg?auto=compress&cs=tinysrgb&w=600" alt="British living room" loading="lazy" />
          </div>

          <!-- Inspiration card (boarding-pass style) -->
          <div class="mood-card">
            <div class="mc-header">
              <svg width="18" height="18" viewBox="0 0 36 36" fill="none">
                <circle cx="18" cy="18" r="17" stroke="#2C3329" stroke-width="1.5"/>
                <path d="M7 21 L18 10 L29 21" stroke="#2C3329" stroke-width="1.5" fill="none"/>
                <rect x="12" y="21" width="5" height="6" stroke="#2C3329" stroke-width="1.2" fill="none"/>
                <rect x="19" y="21" width="5" height="6" stroke="#2C3329" stroke-width="1.2" fill="none"/>
              </svg>
              <span class="mc-brand">BRITISH HOME INTERIOR</span>
            </div>
            <div class="mc-divider"></div>
            <div class="mc-grid">
              <div class="mc-field">
                <span class="mc-label">Room</span>
                <span class="mc-value">LIVING ROOM</span>
              </div>
              <div class="mc-field">
                <span class="mc-label">Style</span>
                <span class="mc-value">COTTAGECORE</span>
              </div>
              <div class="mc-field">
                <span class="mc-label">Budget</span>
                <span class="mc-value">UNDER £200</span>
              </div>
              <div class="mc-field">
                <span class="mc-label">Season</span>
                <span class="mc-value">SPRING 2026</span>
              </div>
            </div>
            <div class="mc-divider"></div>
            <div class="mc-colour">
              <span class="mc-label">Colour of the Moment</span>
              <div class="mc-colour-row">
                <div class="mc-swatch"></div>
                <span class="mc-value">FOREST SAGE</span>
              </div>
            </div>
          </div>

          <!-- Photo B — right, tilted right -->
          <div class="mood-photo mood-photo-b">
            <img src="https://images.pexels.com/photos/2082087/pexels-photo-2082087.jpeg?auto=compress&cs=tinysrgb&w=500" alt="Cosy British bedroom" loading="lazy" />
          </div>

          <!-- Photo C — centre-low, slight tilt -->
          <div class="mood-photo mood-photo-c">
            <img src="https://images.pexels.com/photos/1648768/pexels-photo-1648768.jpeg?auto=compress&cs=tinysrgb&w=400" alt="Room makeover" loading="lazy" />
          </div>

        </div>
      </section>

    </main>

    <Footer />
  </body>
</html>

<style>
  /* ====== HERO ====== */
  .hero {
    position: relative;
    height: 85vh;
    min-height: 500px;
    max-height: 800px;
    overflow: hidden;
    display: flex;
    align-items: center;
    /* Post image always visible as CSS background fallback */
    background-image: var(--hero-bg, none);
    background-size: cover;
    background-position: center;
  }

  .hero-media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, rgba(0,0,0,0.45) 0%, rgba(0,0,0,0.1) 60%, transparent 100%);
  }

  /* Welcome card */
  .hero-card {
    position: relative;
    z-index: 2;
    margin-left: clamp(1.5rem, 6vw, 6rem);
    background: var(--color-gold);
    padding: 2.5rem 2rem 2rem;
    width: clamp(220px, 28vw, 320px);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.5rem;
  }

  .hero-avatar {
    width: 90px;
    height: 90px;
    border-radius: 50%;
    border: 2px solid rgba(255,255,255,0.35);
    margin-bottom: 0.5rem;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255,255,255,0.08);
  }

  .hero-welcome {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    color: #fff;
    margin: 0;
  }

  .hero-tagline {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: rgba(255,255,255,0.85);
    margin: 0;
    line-height: 1.4;
  }

  .hero-cta {
    display: inline-block;
    margin-top: 0.75rem;
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-gold);
    background: #fff;
    padding: 0.55rem 1.25rem;
    text-decoration: none;
    transition: background 200ms, color 200ms;
  }
  .hero-cta:hover { background: var(--color-heading); color: #fff; text-decoration: none; }

  @media (max-width: 500px) {
    .hero { height: 70vh; }
    .hero-card { margin-left: 1rem; margin-right: 1rem; width: calc(100% - 2rem); }
  }

  /* ====== FEATURED POST ====== */
  .featured-section {
    background: var(--color-dark);
    padding-block: 3.5rem 4rem;
  }

  .featured-inner {
    max-width: 1100px;
    margin-inline: auto;
    padding-inline: 2rem;
  }

  .featured-label {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 1.75rem;
  }

  .featured-card {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
  }

  @media (min-width: 700px) {
    .featured-card { grid-template-columns: 1fr 1fr; }
  }

  .featured-img-wrap {
    display: block;
    aspect-ratio: 3/2;
    overflow: hidden;
  }

  .featured-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 400ms ease;
  }
  .featured-img-wrap:hover img { transform: scale(1.04); }

  .featured-body {
    padding: 2rem 2rem 2rem 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.75rem;
  }

  @media (max-width: 699px) {
    .featured-body { padding: 0 1.5rem 1.5rem; }
  }

  .featured-meta {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.45);
    margin: 0;
  }

  .featured-title-link { text-decoration: none; }
  .featured-title {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 2.5vw, 1.7rem);
    font-weight: 700;
    color: #fff;
    line-height: 1.25;
    margin: 0;
    transition: color 200ms;
  }
  .featured-title-link:hover .featured-title { color: var(--color-gold); }

  .featured-excerpt {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.65;
    margin: 0;
  }

  .featured-read {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-gold);
    text-decoration: none;
    border-bottom: 1px solid var(--color-gold);
    padding-bottom: 2px;
    align-self: flex-start;
    transition: color 200ms;
  }
  .featured-read:hover { color: #fff; border-color: #fff; text-decoration: none; }

  /* ====== RECENT POSTS ====== */
  .recent-section {
    background: #fff;
    padding-block: 3.5rem 4rem;
  }

  .recent-inner {
    max-width: 1100px;
    margin-inline: auto;
    padding-inline: 2rem;
  }

  .recent-label {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-heading);
    margin-bottom: 1.75rem;
  }

  .recent-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 600px) {
    .recent-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 900px) {
    .recent-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .recent-card {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border);
  }

  .recent-card-img {
    aspect-ratio: 3/2;
    overflow: hidden;
    background: var(--color-surface);
  }

  .recent-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 400ms ease;
  }
  .recent-card:hover .recent-card-img img { transform: scale(1.04); }

  .recent-card-body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    flex: 1;
  }

  .recent-card-cat {
    font-size: 0.72rem;
    color: var(--color-gold);
    font-style: italic;
  }

  .recent-card-title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-heading);
    line-height: 1.3;
    margin: 0;
    transition: color 200ms;
  }
  .recent-card:hover .recent-card-title { color: var(--color-gold); }

  .recent-card-excerpt {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    line-height: 1.55;
    margin: 0.25rem 0 0;
    flex: 1;
  }

  .recent-card-hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin-block: 0.5rem 0;
  }

  .recent-card-meta {
    font-size: 0.7rem;
    color: var(--color-text-muted);
  }

  /* ====== STATS BAR ====== */
  .stats-bar {
    background: var(--color-gold);
    padding-block: 2rem;
  }

  .stats-inner {
    max-width: 1100px;
    margin-inline: auto;
    padding-inline: 2rem;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    text-align: center;
  }

  @media (min-width: 700px) {
    .stats-inner { grid-template-columns: repeat(4, 1fr); }
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    color: #fff;
  }

  .stat-num {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 700;
    line-height: 1;
  }

  .stat-label {
    font-family: var(--font-body);
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.8);
  }

  /* ====== CATEGORY COLUMNS ====== */
  .page-wrap {
    max-width: 1200px;
    margin-inline: auto;
    padding: 3rem 1rem 4rem;
  }

  @media (min-width: 640px) { .page-wrap { padding-inline: 2rem; } }

  .section-hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin-block: 2.5rem;
  }

  .cat-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .cat-row { grid-template-columns: 1fr 1px 1fr; gap: 0; }
  }

  .cat-col { padding-inline: 0; }

