---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';
import '../styles/global.css';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const sorted = allPosts.sort(
  (a, b) => new Date(b.data.datePublished).getTime() - new Date(a.data.datePublished).getTime()
);

const sliderPosts = sorted.slice(0, 3);

const livingRoom = sorted.filter(p => p.data.category?.toLowerCase().includes('living')).slice(0, 4);
const bedroom    = sorted.filter(p => p.data.category?.toLowerCase().includes('bedroom')).slice(0, 4);
const kitchen    = sorted.filter(p => p.data.category?.toLowerCase().includes('kitchen')).slice(0, 4);
const makeovers  = sorted.filter(p => p.data.category?.toLowerCase().includes('makeover')).slice(0, 4);

const fallback = sorted.slice(0, 4);
const col1 = livingRoom.length ? livingRoom : fallback;
const col2 = bedroom.length    ? bedroom    : fallback;
const col3 = kitchen.length    ? kitchen    : fallback;
const col4 = makeovers.length  ? makeovers  : fallback;

function fmtDate(d: string) {
  return new Date(d).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<html lang="en-GB">
  <head>
    <SEO
      title="British Home Interior — Cosy Styling & Room Makeovers for UK Homes"
      description="Home styling inspiration, room makeovers, and cosy interior ideas for UK homes, flats, and Victorian terraces. In British English, in pounds."
      type="website"
    />
  </head>
  <body>
    <Header />

    <main>

      <!-- ============ HERO SLIDER ============ -->
      <section class="hero-slider" aria-label="Featured articles" aria-live="polite">
        <div class="slider-track" id="slider-track">
          {sliderPosts.map((post, i) => (
            <div class="slide" aria-hidden={i !== 0 ? 'true' : 'false'} data-index={i}>
              <div class="img-wrap slide-img-wrap">
                <img
                  src={post.data.image}
                  alt={post.data.title}
                  width="1400"
                  height="700"
                  loading={i === 0 ? 'eager' : 'lazy'}
                  decoding="async"
                  class="slide-img"
                />
                <a
                  href={`https://pinterest.com/pin/create/button/?url=https://britishhomeinterior.co.uk/blog/${post.slug}/&media=https://britishhomeinterior.co.uk${post.data.image}&description=${encodeURIComponent(post.data.title)}`}
                  class="pinterest-save"
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="Save to Pinterest"
                >
                  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
                  Save
                </a>
              </div>

            </div>
          ))}
        </div>

        <!-- Dots -->
        {sliderPosts.length > 1 && (
          <div class="slider-dots" aria-hidden="true">
            {sliderPosts.map((_, i) => (
              <button class={`slider-dot ${i === 0 ? 'active' : ''}`} data-dot={i} aria-label={`Go to slide ${i + 1}`}></button>
            ))}
          </div>
        )}

        {sliderPosts.length > 1 && (
          <>
            <button class="slider-arrow slider-prev" id="slider-prev" aria-label="Previous slide">&#8592;</button>
            <button class="slider-arrow slider-next" id="slider-next" aria-label="Next slide">&#8594;</button>
          </>
        )}
      </section>

      <!-- ============ CATEGORY COLUMNS ============ -->
      <div class="page-wrap">

        <!-- Row 1: Living Room + Bedroom -->
        <section class="cat-row" aria-label="Living Room and Bedroom">
          <div class="cat-col">
            <h2 class="cat-section-label">Living Room</h2>
            {col1.map(post => (
              <a href={`/blog/${post.slug}/`} class="h-card">
                <div class="h-card-thumb img-wrap">
                  <img src={post.data.image} alt={post.data.title} width="200" height="160" loading="lazy" decoding="async" />
                  <a
                    href={`https://pinterest.com/pin/create/button/?url=https://britishhomeinterior.co.uk/blog/${post.slug}/&media=https://britishhomeinterior.co.uk${post.data.image}&description=${encodeURIComponent(post.data.title)}`}
                    class="pinterest-save" target="_blank" rel="noopener noreferrer"
                    aria-label="Save to Pinterest" onclick="event.stopPropagation();"
                  >
                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
                    Save
                  </a>
                </div>
                <div class="h-card-body">
                  <span class="h-card-cat">{post.data.category ?? 'Interiors'}</span>
                  <span class="h-card-title">{post.data.title}</span>
                  <span class="h-card-meta">
                    <time datetime={post.data.datePublished}>{fmtDate(post.data.datePublished)}</time>
                    &nbsp;·&nbsp;{post.data.readTime ?? '5 mins read'}
                  </span>
                  <p class="h-card-excerpt">{post.data.excerpt ?? post.data.description}</p>
                </div>
              </a>
            ))}
          </div>

          <div class="cat-col-divider" aria-hidden="true"></div>

          <div class="cat-col">
            <h2 class="cat-section-label">Bedroom</h2>
            {col2.map(post => (
              <a href={`/blog/${post.slug}/`} class="h-card">
                <div class="h-card-thumb img-wrap">
                  <img src={post.data.image} alt={post.data.title} width="200" height="160" loading="lazy" decoding="async" />
                  <a
                    href={`https://pinterest.com/pin/create/button/?url=https://britishhomeinterior.co.uk/blog/${post.slug}/&media=https://britishhomeinterior.co.uk${post.data.image}&description=${encodeURIComponent(post.data.title)}`}
                    class="pinterest-save" target="_blank" rel="noopener noreferrer"
                    aria-label="Save to Pinterest" onclick="event.stopPropagation();"
                  >
                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
                    Save
                  </a>
                </div>
                <div class="h-card-body">
                  <span class="h-card-cat">{post.data.category ?? 'Interiors'}</span>
                  <span class="h-card-title">{post.data.title}</span>
                  <span class="h-card-meta">
                    <time datetime={post.data.datePublished}>{fmtDate(post.data.datePublished)}</time>
                    &nbsp;·&nbsp;{post.data.readTime ?? '5 mins read'}
                  </span>
                  <p class="h-card-excerpt">{post.data.excerpt ?? post.data.description}</p>
                </div>
              </a>
            ))}
          </div>
        </section>

        <hr class="section-hr" />

        <!-- Row 2: Kitchen + Room Makeovers -->
        <section class="cat-row" aria-label="Kitchen and Room Makeovers">
          <div class="cat-col">
            <h2 class="cat-section-label">Kitchen</h2>
            {col3.map(post => (
              <a href={`/blog/${post.slug}/`} class="h-card">
                <div class="h-card-thumb img-wrap">
                  <img src={post.data.image} alt={post.data.title} width="200" height="160" loading="lazy" decoding="async" />
                </div>
                <div class="h-card-body">
                  <span class="h-card-cat">{post.data.category ?? 'Interiors'}</span>
                  <span class="h-card-title">{post.data.title}</span>
                  <span class="h-card-meta">
                    <time datetime={post.data.datePublished}>{fmtDate(post.data.datePublished)}</time>
                    &nbsp;·&nbsp;{post.data.readTime ?? '5 mins read'}
                  </span>
                  <p class="h-card-excerpt">{post.data.excerpt ?? post.data.description}</p>
                </div>
              </a>
            ))}
          </div>

          <div class="cat-col-divider" aria-hidden="true"></div>

          <div class="cat-col">
            <h2 class="cat-section-label">Room Makeovers</h2>
            {col4.map(post => (
              <a href={`/blog/${post.slug}/`} class="h-card">
                <div class="h-card-thumb img-wrap">
                  <img src={post.data.image} alt={post.data.title} width="200" height="160" loading="lazy" decoding="async" />
                </div>
                <div class="h-card-body">
                  <span class="h-card-cat">{post.data.category ?? 'Interiors'}</span>
                  <span class="h-card-title">{post.data.title}</span>
                  <span class="h-card-meta">
                    <time datetime={post.data.datePublished}>{fmtDate(post.data.datePublished)}</time>
                    &nbsp;·&nbsp;{post.data.readTime ?? '5 mins read'}
                  </span>
                  <p class="h-card-excerpt">{post.data.excerpt ?? post.data.description}</p>
                </div>
              </a>
            ))}
          </div>
        </section>

      </div><!-- /page-wrap -->

    </main>

    <Footer />
  </body>
</html>

<script>
  // ---- Hero Slider ----
  const track    = document.getElementById('slider-track');
  const slides   = track?.querySelectorAll('.slide') as NodeListOf<HTMLElement>;
  const prevBtn  = document.getElementById('slider-prev');
  const nextBtn  = document.getElementById('slider-next');
  const dots     = document.querySelectorAll('.slider-dot') as NodeListOf<HTMLButtonElement>;

  if (slides && slides.length > 1) {
    let current = 0;

    function goTo(index: number) {
      slides[current].classList.remove('active');
      slides[current].setAttribute('aria-hidden', 'true');
      dots[current]?.classList.remove('active');
      current = (index + slides.length) % slides.length;
      slides[current].classList.add('active');
      slides[current].setAttribute('aria-hidden', 'false');
      dots[current]?.classList.add('active');
    }

    slides[0].classList.add('active');
    dots[0]?.classList.add('active');

    prevBtn?.addEventListener('click', () => { clearInterval(timer); goTo(current - 1); timer = setInterval(() => goTo(current + 1), 6000); });
    nextBtn?.addEventListener('click', () => { clearInterval(timer); goTo(current + 1); timer = setInterval(() => goTo(current + 1), 6000); });
    dots.forEach(dot => dot.addEventListener('click', () => { clearInterval(timer); goTo(Number(dot.dataset.dot)); timer = setInterval(() => goTo(current + 1), 6000); }));

    let timer = setInterval(() => goTo(current + 1), 6000);

    // Touch swipe support for mobile
    let touchStartX = 0;
    track?.addEventListener('touchstart', (e: TouchEvent) => { touchStartX = e.touches[0].clientX; }, { passive: true });
    track?.addEventListener('touchend', (e: TouchEvent) => {
      const diff = touchStartX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 40) {
        clearInterval(timer);
        goTo(diff > 0 ? current + 1 : current - 1);
        timer = setInterval(() => goTo(current + 1), 6000);
      }
    }, { passive: true });

  } else if (slides?.length === 1) {
    slides[0].classList.add('active');
  }
</script>

<style>
  /* ============ PAGE WRAP ============ */
  .page-wrap {
    max-width: 1200px;
    margin-inline: auto;
    padding: 3rem 1rem 4rem;
  }

  @media (min-width: 640px) {
    .page-wrap { padding-inline: 2rem; }
  }

  .section-hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin-block: 2.5rem;
  }

  /* ============ CATEGORY ROWS ============ */
  .cat-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .cat-row {
      grid-template-columns: 1fr 1px 1fr;
      gap: 0;
    }
  }

  .cat-col { padding-inline: 0; }

  @media (min-width: 768px) {
    .cat-col:first-child { padding-right: 2.5rem; }
    .cat-col:last-child  { padding-left: 2.5rem; }
  }

  .cat-col-divider {
    background: var(--color-border);
    width: 1px;
    display: none;
  }

  @media (min-width: 768px) {
    .cat-col-divider { display: block; }
  }

  /* ============ HERO SLIDER ============ */
  .hero-slider {
    position: relative;
    overflow: hidden;
    background: var(--color-surface);
  }

  .slider-track {
    position: relative;
    width: 100%;
  }

  .slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 600ms ease;
    pointer-events: none;
  }

  .slide.active {
    opacity: 1;
    pointer-events: auto;
    position: relative;
  }

  .slide:first-child { opacity: 1; position: relative; pointer-events: auto; }

  .slide-img-wrap {
    width: 100%;
    aspect-ratio: 16/7;
    overflow: hidden;
  }

  @media (max-width: 640px) {
    .slide-img-wrap { aspect-ratio: 4/3; }
  }

  .slide-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Dots */
  .slider-dots {
    display: flex;
    justify-content: center;
    gap: 0.6rem;
    padding: 1rem 0 0.5rem;
  }

  .slider-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #D4C8BE;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background-color 200ms ease, transform 200ms ease;
  }

  .slider-dot.active {
    background: var(--color-gold);
    transform: scale(1.25);
  }

  .slider-dot:hover { background: var(--color-gold); }

  /* Arrows */
  .slider-arrow {
    position: absolute;
    top: 35%;
    transform: translateY(-50%);
    z-index: 10;
    background: #fff;
    border: none;
    width: 38px;
    height: 38px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    color: var(--color-heading);
    cursor: pointer;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    transition: background-color var(--transition-base), color var(--transition-base);
  }

  .slider-arrow:hover {
    background: var(--color-heading);
    color: #fff;
  }

  .slider-prev { left: 0.75rem; }
  .slider-next { right: 0.75rem; }

  @media (max-width: 480px) {
    .slider-arrow { display: none; }
  }
</style>
